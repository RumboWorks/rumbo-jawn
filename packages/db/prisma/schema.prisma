// Rumbo database schema — MySQL (MariaDB-compatible).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---- Auth / Users ----

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lastLoginAt   DateTime?
  memberships   Membership[]
  oauthAccounts OAuthAccount[]
  jobs          Job[]
}

model OAuthAccount {
  id         String @id @default(cuid())
  provider   String
  providerId String
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

// ---- Organizations ----

model Organization {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  memberships     Membership[]
  approvedDomains ApprovedDomain[]
  jobs            Job[]
}

model Membership {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  role      MemberRole   @default(MEMBER)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model ApprovedDomain {
  id     String       @id @default(cuid())
  domain String
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([domain, orgId])
  @@index([orgId])
}

// ---- Sessions ----

model Session {
  id        String    @id
  sid       String    @unique
  data      String    @db.MediumText
  expiresAt DateTime?
}

// ---- Jobs ----

model Job {
  id          String     @id @default(cuid())
  type        String                    // e.g. 'slu.analysis'
  status      JobStatus  @default(PENDING)
  userId      String?
  orgId       String?
  payload     Json?                     // input parameters
  result      Json?                     // summary output
  errorMsg    String?    @db.Text
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  org         Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  aiCalls     AiCall[]
  artifacts   ArtifactManifest[]

  @@index([status, createdAt])
  @@index([userId])
  @@index([orgId])
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  CANCELLED
}

// ---- AI calls / cost logging ----

model AiCall {
  id           String   @id @default(cuid())
  jobId        String?
  callType     String                    // e.g. 'crawl.summarize', 'guidance.generate'
  provider     String                    // 'openai' | 'anthropic' | 'deepseek'
  model        String
  promptTokens Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  costUsd      Decimal  @default(0) @db.Decimal(10,6)
  durationMs   Int?
  cacheHit     Boolean  @default(false)
  createdAt    DateTime @default(now())
  job          Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([provider, createdAt])
}

// ---- Storage / artifacts ----

model ArtifactManifest {
  id          String   @id @default(cuid())
  jobId       String?
  type        String                    // e.g. 'crawl.raw', 'guidance.profile'
  storagePath String                    // relative path within storage root
  sizeBytes   Int?
  mimeType    String?
  meta        Json?
  createdAt   DateTime @default(now())
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId])
}
