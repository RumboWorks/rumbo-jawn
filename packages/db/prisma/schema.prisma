// Rumbo database schema — MySQL (MariaDB-compatible).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---- Auth / Users ----

model User {
  id                        String                      @id @default(cuid())
  email                     String                      @unique
  name                      String?
  firstName                 String?
  lastName                  String?
  avatarUrl                 String?
  passwordHash              String?
  status                    UserStatus                  @default(ACTIVE)
  statusReason              String?                     @db.Text
  statusChangedAt           DateTime?
  isPlatformAdmin           Boolean                     @default(false)
  navOrientation            NavOrientation?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  lastLoginAt               DateTime?
  memberships               Membership[]
  partnerMemberships        PartnerMembership[]
  organizationsCreated      Organization[]              @relation("OrganizationCreatedBy")
  partnerOrgAccessesCreated PartnerOrganizationAccess[] @relation("PartnerOrgAccessCreatedBy")
  billingResponsibilities   OrganizationEntitlement[]   @relation("BillingResponsibleUser")
  adminAuditLogs            AdminAuditLog[]             @relation("AdminAuditActor")
  invitesSent               OrganizationInvite[]        @relation("OrganizationInviteSentBy")
  oauthAccounts             OAuthAccount[]
  passwordResetTokens       PasswordResetToken[]
  jobs                      Job[]
  toolGrants                ToolGrant[]
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum NavOrientation {
  HORIZONTAL
  VERTICAL
}

model OAuthAccount {
  id         String @id @default(cuid())
  provider   String
  providerId String
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

// ---- Organizations ----

model Organization {
  id               String                      @id @default(cuid())
  publicId         String                      @unique @default(cuid())
  name             String
  slug             String                      @unique
  organizationType OrgType                     @default(SOLO)
  createdByUserId  String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  deletedAt        DateTime?
  createdBy        User?                       @relation("OrganizationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  memberships      Membership[]
  invites          OrganizationInvite[]
  partnerAccesses  PartnerOrganizationAccess[]
  entitlement      OrganizationEntitlement?
  usageEvents      UsageEvent[]
  adminAuditLogs   AdminAuditLog[]
  approvedDomains  ApprovedDomain[]
  jobs             Job[]
  toolGrants       ToolGrant[]

  @@index([createdByUserId])
}

model Membership {
  id                  String                    @id @default(cuid())
  userId              String
  orgId               String
  role                MemberRole                @default(MEMBER)
  createdAt           DateTime                  @default(now())
  user                User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  org                 Organization              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  billingEntitlements OrganizationEntitlement[]

  @@unique([userId, orgId])
  @@index([orgId])
}

enum MemberRole {
  MANAGER
  MEMBER
}

// Per-user, per-tool access grant. Layers on top of org Membership.
// Absence of a row for (userId, orgId, tool) means NO ACCESS to that tool.
// Tool keys come from @rumbo/config tool registry.
model ToolGrant {
  id        String     @id @default(cuid())
  userId    String
  orgId     String
  tool      String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId, tool])
  @@index([userId])
  @@index([orgId, tool])
}

enum OrgType {
  SOLO
  NONPROFIT
  AGENCY
  ENTERPRISE
}

model OrganizationInvite {
  id              String     @id @default(cuid())
  orgId           String
  email           String
  role            MemberRole @default(MEMBER)
  invitedByUserId String?
  inviteToken     String     @unique @default(cuid())
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime   @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy User?        @relation("OrganizationInviteSentBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([email])
  @@index([invitedByUserId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ApprovedDomain {
  id     String       @id @default(cuid())
  domain String
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([domain, orgId])
  @@index([orgId])
}

model PartnerAccount {
  id           String   @id @default(cuid())
  publicId     String   @unique @default(cuid())
  name         String
  logoUrl      String?
  primaryColor String?
  supportEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships PartnerMembership[]
  orgAccesses PartnerOrganizationAccess[]
}

model PartnerMembership {
  id               String      @id @default(cuid())
  partnerAccountId String
  userId           String
  role             PartnerRole @default(MANAGER)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  partnerAccount PartnerAccount @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partnerAccountId, userId])
  @@index([partnerAccountId])
  @@index([userId])
}

model PartnerOrganizationAccess {
  id               String    @id @default(cuid())
  partnerAccountId String
  orgId            String
  createdByUserId  String?
  createdAt        DateTime  @default(now())
  removedAt        DateTime?

  partnerAccount PartnerAccount @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  org            Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy      User?          @relation("PartnerOrgAccessCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([partnerAccountId])
  @@index([orgId])
  @@index([createdByUserId])
}

enum PartnerRole {
  MANAGER
}

// ---- Entitlements / billing readiness ----

model ProductTier {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?  @db.Text
  limits      Json?
  features    Json?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entitlements OrganizationEntitlement[]
}

model OrganizationEntitlement {
  id                             String    @id @default(cuid())
  orgId                          String    @unique
  tierId                         String
  billingResponsibleUserId       String?
  billingResponsibleMembershipId String?
  aiSpendCapUsd                  Decimal   @default(25.000000) @db.Decimal(10, 6)
  stripeCustomerId               String?
  stripeSubscriptionId           String?
  stripePriceId                  String?
  stripeSubscriptionStatus       String?
  stripeCurrentPeriodStart       DateTime?
  stripeCurrentPeriodEnd         DateTime?
  stripeCancelAtPeriodEnd        Boolean   @default(false)
  overrides                      Json?
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  org                          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tier                         ProductTier  @relation(fields: [tierId], references: [id])
  billingResponsibleUser       User?        @relation("BillingResponsibleUser", fields: [billingResponsibleUserId], references: [id], onDelete: SetNull)
  billingResponsibleMembership Membership?  @relation(fields: [billingResponsibleMembershipId], references: [id], onDelete: SetNull)

  @@index([tierId])
  @@index([billingResponsibleUserId])
  @@index([billingResponsibleMembershipId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model UsageEvent {
  id        String   @id @default(cuid())
  orgId     String
  tool      String
  usageKey  String
  quantity  Int      @default(1)
  jobId     String?
  meta      Json?
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([orgId, tool, usageKey, createdAt])
  @@index([jobId])
}

model FeatureFlag {
  id        String   @id @default(cuid())
  key       String
  scope     String   @default("platform")
  scopeId   String?
  tool      String?
  enabled   Boolean  @default(false)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, scope, scopeId, tool])
  @@index([scope, scopeId])
  @@index([tool])
}

model AiModelConfig {
  id          String   @id @default(cuid())
  tool        String   @default("platform")
  callType    String
  provider    String
  model       String
  scope       String   @default("platform")
  scopeId     String?
  temperature Float?
  maxTokens   Int?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tool, callType, scope, scopeId])
  @@index([tool])
  @@index([scope, scopeId])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String
  orgId      String?
  oldValue   Json?
  newValue   Json?
  reason     String?  @db.Text
  createdAt  DateTime @default(now())

  actor User?         @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([orgId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// ---- Sessions ----

model Session {
  id        String    @id
  sid       String    @unique
  data      String    @db.MediumText
  expiresAt DateTime?
}

// ---- Jobs ----

model Job {
  id          String             @id @default(cuid())
  type        String // e.g. 'slu.analysis'
  status      JobStatus          @default(PENDING)
  userId      String?
  orgId       String?
  payload     Json? // input parameters
  result      Json? // summary output
  errorMsg    String?            @db.Text
  attempts    Int                @default(0)
  maxAttempts Int                @default(3)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  org         Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  aiCalls     AiCall[]
  artifacts   ArtifactManifest[]
  usageEvents UsageEvent[]

  @@index([status, createdAt])
  @@index([userId])
  @@index([orgId])
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
  CANCELLED
}

// ---- AI calls / cost logging ----

model AiCall {
  id           String   @id @default(cuid())
  jobId        String?
  callType     String // e.g. 'crawl.summarize', 'guidance.generate'
  provider     String // 'openai' | 'anthropic' | 'deepseek'
  model        String
  promptTokens Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  costUsd      Decimal  @default(0) @db.Decimal(10, 6)
  durationMs   Int?
  cacheHit     Boolean  @default(false)
  createdAt    DateTime @default(now())
  job          Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([provider, createdAt])
}

// ---- Storage / artifacts ----

model ArtifactManifest {
  id          String   @id @default(cuid())
  jobId       String?
  type        String // e.g. 'crawl.raw', 'guidance.profile'
  storagePath String // relative path within storage root
  sizeBytes   Int?
  mimeType    String?
  meta        Json?
  createdAt   DateTime @default(now())
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId])
}

// ---- Sounds Like Us — Feedback ----

model SluFeedback {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  orgId     String?
  rating    Int // 1–5
  comment   String?  @db.Text
  category  String? // 'sounds_right' | 'sounds_wrong' | etc.
  options   Json? // selected workbench options at time of feedback
  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([userId])
}

// ============================================================================
// Eval (formerly Model Eval) — second tool.
//
// Conventions: String cuid IDs; UPPERCASE enums; tables prefixed `Eval`.
// References to platform User/Organization are scalar FKs (userId/organizationId)
// with indexes but no Prisma relation (matching SluFeedback), so the shared
// User/Organization models stay free of tool back-relations. Relations are
// declared only among Eval tables.
// ============================================================================

// ---- Eval: model catalog ----

model EvalProvider {
  id           String           @id @default(cuid())
  name         String           @unique
  providerType EvalProviderType
  createdAt    DateTime         @default(now())

  providerModels EvalProviderModel[]
  orgModels      EvalOrgModel[]
}

model EvalProviderModel {
  id            String   @id @default(cuid())
  providerId    String
  name          String
  apiIdentifier String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  provider  EvalProvider   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  orgModels EvalOrgModel[]

  @@unique([providerId, apiIdentifier])
  @@index([providerId])
}

model EvalOrgModel {
  id              String           @id @default(cuid())
  organizationId  String
  providerId      String?
  providerModelId String?
  displayName     String
  notes           String?          @db.Text
  accessMethod    EvalAccessMethod
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  provider       EvalProvider?       @relation(fields: [providerId], references: [id], onDelete: SetNull)
  providerModel  EvalProviderModel?  @relation(fields: [providerModelId], references: [id], onDelete: SetNull)
  modelSnapshots EvalModelSnapshot[]

  @@index([organizationId])
  @@index([providerId])
  @@index([providerModelId])
}

// ---- Eval: criteria ----

model EvalCriterion {
  id              String    @id @default(cuid())
  organizationId  String
  title           String
  description     String?   @db.Text
  displayOrder    Int       @default(0)
  createdByUserId String
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
}

// ---- Eval: evaluations & runs ----

model Eval {
  id              String    @id @default(cuid())
  publicId        String    @unique @default(cuid())
  organizationId  String
  title           String
  description     String?   @db.Text
  createdByUserId String
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  runs EvalRun[]

  @@index([organizationId])
}

model EvalRun {
  id                String        @id @default(cuid())
  publicId          String        @unique @default(cuid())
  organizationId    String
  evalId            String
  runNumber         Int
  status            EvalRunStatus @default(DRAFT)
  hideModelNames    Boolean       @default(false)
  hidePeerReviews   Boolean       @default(false)
  reviewClosesAt    DateTime?
  launchedByUserId  String?
  completedByUserId String?
  archivedByUserId  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  completedAt       DateTime?
  archivedAt        DateTime?

  eval               Eval                    @relation(fields: [evalId], references: [id], onDelete: Cascade)
  promptSnapshot     EvalPromptSnapshot?
  criterionSnapshots EvalCriterionSnapshot[]
  modelSnapshots     EvalModelSnapshot[]
  responses          EvalResponse[]
  reviewAssignments  EvalReviewAssignment[]
  ratings            EvalRating[]
  comments           EvalReviewComment[]
  report             EvalReport?
  tasks              EvalTask[]

  @@index([organizationId])
  @@index([evalId])
  @@index([status])
}

// ---- Eval: immutable snapshots captured at run launch ----

model EvalPromptSnapshot {
  id         String   @id @default(cuid())
  evalRunId  String   @unique
  promptText String   @db.Text
  createdAt  DateTime @default(now())

  evalRun EvalRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
}

model EvalCriterionSnapshot {
  id                String   @id @default(cuid())
  evalRunId         String
  sourceCriterionId String?
  title             String
  description       String?  @db.Text
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now())

  evalRun EvalRun      @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  ratings EvalRating[]

  @@index([evalRunId])
}

model EvalModelSnapshot {
  id                String   @id @default(cuid())
  evalRunId         String
  orgModelId        String
  displayName       String
  providerName      String?
  providerModelName String?
  isManual          Boolean  @default(false)
  isApiPending      Boolean  @default(false)
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now())

  evalRun   EvalRun        @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  orgModel  EvalOrgModel   @relation(fields: [orgModelId], references: [id])
  responses EvalResponse[]

  @@index([evalRunId])
  @@index([orgModelId])
}

// ---- Eval: responses ----

model EvalResponse {
  id              String             @id @default(cuid())
  publicId        String             @unique @default(cuid())
  organizationId  String
  evalRunId       String
  modelSnapshotId String
  responseSource  EvalResponseSource
  responseText    String?            @db.LongText
  submittedByUserId String?
  submittedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  evalRun       EvalRun             @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  modelSnapshot EvalModelSnapshot   @relation(fields: [modelSnapshotId], references: [id], onDelete: Cascade)
  ratings       EvalRating[]
  comments      EvalReviewComment[]
  tasks         EvalTask[]

  @@index([organizationId])
  @@index([evalRunId])
  @@index([modelSnapshotId])
}

// ---- Eval: review workflow ----

model EvalReviewAssignment {
  id               String    @id @default(cuid())
  organizationId   String
  evalRunId        String
  userId           String
  assignedByUserId String
  assignedAt       DateTime  @default(now())
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  evalRun EvalRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)

  @@unique([evalRunId, userId])
  @@index([organizationId])
  @@index([userId])
}

model EvalRating {
  id                  String    @id @default(cuid())
  organizationId      String
  evalRunId           String
  responseId          String
  criterionSnapshotId String
  reviewerUserId      String
  score               Int
  submittedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  evalRun           EvalRun               @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  response          EvalResponse          @relation(fields: [responseId], references: [id], onDelete: Cascade)
  criterionSnapshot EvalCriterionSnapshot @relation(fields: [criterionSnapshotId], references: [id], onDelete: Cascade)

  @@unique([evalRunId, responseId, criterionSnapshotId, reviewerUserId])
  @@index([organizationId])
  @@index([evalRunId])
  @@index([responseId])
  @@index([criterionSnapshotId])
}

model EvalReviewComment {
  id             String   @id @default(cuid())
  organizationId String
  evalRunId      String
  responseId     String?
  reviewerUserId String
  commentText    String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  evalRun  EvalRun       @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  response EvalResponse? @relation(fields: [responseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([evalRunId])
  @@index([responseId])
}

// ---- Eval: report ----

model EvalReport {
  id                 String   @id @default(cuid())
  organizationId     String
  evalRunId          String   @unique
  summaryText        String?  @db.Text
  recommendationText String?  @db.Text
  secureShareEnabled Boolean  @default(false)
  secureShareToken   String?  @unique
  createdByUserId    String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  evalRun EvalRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ---- Eval: tasks & notifications ----

model EvalTask {
  id             String         @id @default(cuid())
  organizationId String
  assignedUserId String
  evalRunId      String?
  responseId     String?
  taskType       EvalTaskType
  status         EvalTaskStatus @default(OPEN)
  dueAt          DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  evalRun       EvalRun?           @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  response      EvalResponse?      @relation(fields: [responseId], references: [id], onDelete: Cascade)
  notifications EvalNotification[]

  @@index([organizationId])
  @@index([assignedUserId])
  @@index([status])
}

model EvalNotification {
  id               String                  @id @default(cuid())
  recipientUserId  String
  organizationId   String
  evalRunId        String?
  taskId           String?
  notificationType EvalNotificationType
  channel          EvalNotificationChannel
  readAt           DateTime?
  sentAt           DateTime?
  createdAt        DateTime                @default(now())

  task EvalTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([recipientUserId])
  @@index([organizationId])
  @@index([taskId])
}

// ---- Eval: enums ----

enum EvalProviderType {
  OPENAI
  ANTHROPIC
  GOOGLE
  MANUAL
  OTHER
}

enum EvalAccessMethod {
  PLATFORM_API
  PLATFORM_API_PENDING
  ORGANIZATION_API
  MANUAL
}

enum EvalRunStatus {
  DRAFT
  COLLECTING_RESPONSES
  READY_FOR_REVIEWS
  IN_REVIEW
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum EvalResponseSource {
  PLATFORM_API
  ORGANIZATION_API
  MANUAL
  SEED_DATA
}

enum EvalTaskType {
  REVIEW_RESPONSES
  COLLECT_MANUAL_RESPONSE
  ACCEPT_INVITE
  COMPLETE_SETUP
}

enum EvalTaskStatus {
  OPEN
  COMPLETED
  CANCELLED
  OVERDUE
}

enum EvalNotificationType {
  REVIEW_ASSIGNED
  REVIEW_REMINDER
  EVAL_COMPLETED
  INVITE_RECEIVED
  MANUAL_RESPONSE_NEEDED
}

enum EvalNotificationChannel {
  EMAIL
  IN_APP
}
