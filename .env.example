NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=mysql://user:password@localhost:3306/rumbo_dev

# AI providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Auth (OAuth — populated in Phase 02)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yourdomain.example.com/auth/google/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
SESSION_SECRET=changeme

# Email (SMTP; leave unset or EMAIL_TRANSPORT=log to log instead of sending)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_SMTP_SECURE=false
EMAIL_FROM="Rumbo <no-reply@yourdomain.example.com>"
EMAIL_TRANSPORT=log

# Stripe (billing; without these, billing pages render an unconfigured state)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Support contact shown on /support
SUPPORT_EMAIL=support@yourdomain.example.com
