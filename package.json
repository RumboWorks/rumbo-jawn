{
  "name": "rumbo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "tools/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:web": "node apps/platform-web/src/index.js",
    "dev:worker": "node apps/worker/src/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "qa": "npx playwright test",
    "qa:headed": "npx playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
