{% extends currentUser ? "layouts/app.twig" : "layouts/base.twig" %}

{% block title %}{{ status }} — Rumbo{% endblock %}

{% block content %}
<div class="{% if not currentUser %}rj-container {% endif %}rj-error-page">
    <p class="rj-eyebrow">{{ status }}</p>
    <h1 class="rj-h1">
        {%- if status == 404 -%}
            Page not found
        {%- elseif status == 403 -%}
            You don't have access to that
        {%- else -%}
            Something went wrong
        {%- endif -%}
    </h1>
    <p class="rj-lead">{{ message }}</p>
    <div class="rj-error-page__actions">
        <a href="/" class="rj-btn rj-btn--primary">Go home</a>
        {% if currentUser %}
            <a href="/account" class="rj-btn rj-btn--ghost">My account</a>
        {% endif %}
    </div>
</div>
{% endblock %}
