{% extends "layouts/app.twig" %}

{% block title %}New client organization — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/partner/_sidebar.twig" with { active: 'org-new' } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: 'New client organization',
        subtitle: 'Creates an organization under your partner account. You get manager access automatically.'
    } %}

    {% include "pages/admin/_flash.twig" %}

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Details</h2></div>
        <div class="rj-admin-panel__body">
            <form class="rj-admin-form" method="post" action="/partner/orgs">
                {% if accounts|length == 1 %}
                    <input type="hidden" name="partnerAccountId" value="{{ accounts[0].id }}">
                {% else %}
                    <label>
                        <span>Partner account</span>
                        <select name="partnerAccountId" required>
                            {% for account in accounts %}
                                <option value="{{ account.id }}">{{ account.name }}</option>
                            {% endfor %}
                        </select>
                    </label>
                {% endif %}
                <label>
                    <span>Name</span>
                    <input type="text" name="name" required>
                </label>
                <label>
                    <span>Type</span>
                    <select name="organizationType">
                        <option value="SOLO">Solo</option>
                        <option value="NONPROFIT" selected>Nonprofit</option>
                        <option value="AGENCY">Agency</option>
                        <option value="ENTERPRISE">Enterprise</option>
                    </select>
                </label>
                <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                    <i data-lucide="plus"></i> Create organization
                </button>
            </form>
        </div>
    </section>
{% endblock %}
