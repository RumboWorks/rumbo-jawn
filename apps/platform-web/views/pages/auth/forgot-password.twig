{% extends "layouts/base.twig" %}

{% block title %}Reset password — Rumbo{% endblock %}

{% block content %}
<div class="rj-container">
    <div class="rj-auth-box">
        <h1 class="rj-auth-box__heading">Reset password</h1>

        {% if flash_error %}
            <div class="rj-alert rj-alert--danger">
                <i data-lucide="circle-x"></i>
                <div class="rj-alert__body">{{ flash_error }}</div>
            </div>
        {% endif %}
        {% if flash_success %}
            <div class="rj-alert rj-alert--success">
                <i data-lucide="check-circle-2"></i>
                <div class="rj-alert__body">{{ flash_success }}</div>
            </div>
        {% endif %}

        <form method="POST" action="/password/forgot" class="rj-form">
            <div class="rj-form-group">
                <label class="rj-label" for="email">Email</label>
                <input class="rj-input" type="email" id="email" name="email" autocomplete="email" required placeholder="you@example.org">
            </div>
            <button type="submit" class="rj-btn rj-btn--primary">Send reset link</button>
        </form>

        <p class="rj-auth-box__footer">
            Remembered it? <a href="/login">Sign in</a>
        </p>
    </div>
</div>
{% endblock %}
