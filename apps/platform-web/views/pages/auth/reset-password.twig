{% extends "layouts/base.twig" %}

{% block title %}Choose new password — Rumbo{% endblock %}

{% block content %}
<div class="rj-container">
    <div class="rj-auth-box">
        <h1 class="rj-auth-box__heading">Choose a new password</h1>

        {% if flash_error %}
            <div class="rj-alert rj-alert--danger">
                <i data-lucide="circle-x"></i>
                <div class="rj-alert__body">{{ flash_error }}</div>
            </div>
        {% endif %}

        <form method="POST" action="/password/reset/{{ token }}" class="rj-form">
            <div class="rj-form-group">
                <label class="rj-label" for="password">New password</label>
                <input class="rj-input" type="password" id="password" name="password" autocomplete="new-password" required minlength="8">
                <span class="rj-form-hint">At least 8 characters.</span>
            </div>
            <button type="submit" class="rj-btn rj-btn--primary">Update password</button>
        </form>
    </div>
</div>
{% endblock %}
