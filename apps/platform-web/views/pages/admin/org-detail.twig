{% extends "layouts/app.twig" %}

{% block title %}{{ org.name }} — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header rj-page-header--with-action">
        <div class="rj-page-header__text">
            {% include "pages/admin/_breadcrumbs.twig" with { sectionLabel: 'organizations', sectionHref: '/admin/orgs' } %}
            <h1>{{ org.name }}</h1>
            <p>{{ org.slug }} · <span class="rj-admin-mono">{{ org.publicId }}</span></p>
        </div>
        <form method="post" action="/organization/switch" class="rj-page-header__action">
            <input type="hidden" name="orgId" value="{{ org.id }}">
            <input type="hidden" name="returnTo" value="/">
            <button type="submit" class="rj-btn rj-btn--secondary rj-btn--sm">
                <i data-lucide="arrow-left-right"></i> Act as this organization
            </button>
        </form>
    </div>

    {% include "pages/admin/_flash.twig" %}

    <section class="rj-admin-metrics rj-admin-metrics--compact">
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Tier</span>
            <strong>{{ org.entitlement.tier.name }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Runs used</span>
            <strong>{{ org.sluBudgetStatus.used }} / {{ org.sluBudgetStatus.limit }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Budget</span>
            <strong>{% if org.sluBudgetStatus.overBudget %}Over{% else %}Ok{% endif %}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Spend cap</span>
            <strong>${{ org.spendStatus.capUsd|number_format(2, '.', ',') }}</strong>
        </div>
    </section>

    <div class="rj-admin-detail-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Invite member</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/invites">
                    <label>
                        <span>Email</span>
                        <input type="email" name="email" placeholder="person@example.org" required>
                    </label>
                    <label>
                        <span>Role</span>
                        <select name="role">
                            <option value="MEMBER">Member</option>
                            <option value="MANAGER">Manager</option>
                        </select>
                    </label>
                    <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">
                        <i data-lucide="plus"></i> Send invite
                    </button>
                </form>
            </div>
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Pending invites</h2></div>
            <div class="rj-admin-panel__body">
                {% if org.invites|length == 0 %}
                    <p class="rj-admin-empty">No pending invites.</p>
                {% else %}
                    <div class="rj-table-wrap">
                        <table class="rj-table rj-admin-table">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Expires</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for invite in org.invites %}
                                    <tr>
                                        <td>{{ invite.email }}</td>
                                        <td>{{ invite.role|lower }}</td>
                                        <td class="rj-num">{{ invite.expiresAt|date("M j, Y") }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Members</h2></div>
        <div class="rj-admin-panel__body">
        <div class="rj-table-wrap">
            <table class="rj-table rj-admin-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for membership in org.memberships %}
                        <tr>
                            <td>
                                <a href="/admin/users/{{ membership.user.id }}">{{ membership.user.email }}</a>
                                <br><span class="rj-admin-muted">{{ membership.user.name ?? 'No name' }}</span>
                            </td>
                            <td>
                                <form class="rj-admin-inline-form" method="post" action="/admin/orgs/{{ org.id }}/memberships/{{ membership.id }}/role">
                                    <select name="role">
                                        <option value="MEMBER"{% if membership.role == 'MEMBER' %} selected{% endif %}>Member</option>
                                        <option value="MANAGER"{% if membership.role == 'MANAGER' %} selected{% endif %}>Manager</option>
                                    </select>
                                    <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">Update</button>
                                </form>
                            </td>
                            <td class="rj-num">{{ membership.createdAt|date("M j, Y") }}</td>
                            <td>
                                <form method="post" action="/admin/orgs/{{ org.id }}/memberships/{{ membership.id }}/remove">
                                    <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit">Remove</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="rj-table__empty">No members found.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        </div>
    </section>

    <div class="rj-admin-detail-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Tier</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/tier">
                    <label>
                        <span>Product tier</span>
                        <select name="tierKey">
                            {% for tier in org.tiers %}
                                <option value="{{ tier.key }}"{% if org.entitlement.tier.key == tier.key %} selected{% endif %}>{{ tier.name }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label>
                        <span>Reason</span>
                        <input type="text" name="reason" placeholder="Optional">
                    </label>
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                        <i data-lucide="save"></i> Save tier
                    </button>
                </form>
            </div>
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Billing responsibility</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/billing-responsible">
                    <label>
                        <span>Manager</span>
                        <select name="membershipId">
                            <option value="">Unassigned</option>
                            {% for membership in org.managerMemberships %}
                                <option value="{{ membership.id }}"{% if org.entitlement.billingResponsibleMembershipId == membership.id %} selected{% endif %}>
                                    {{ membership.user.email }}
                                </option>
                            {% endfor %}
                        </select>
                    </label>
                    <label>
                        <span>Reason</span>
                        <input type="text" name="reason" placeholder="Optional">
                    </label>
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                        <i data-lucide="save"></i> Save billing person
                    </button>
                </form>
            </div>
        </section>
    </div>

    <div class="rj-admin-detail-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Sounds Like Us budget</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/usage-budget">
                    <label>
                        <span>Runs</span>
                        <input type="number" name="limit" min="0" step="1" value="{{ org.sluBudgetStatus.limit }}">
                    </label>
                    <label>
                        <span>Window days</span>
                        <input type="number" name="windowDays" min="1" step="1" value="{{ org.sluBudgetStatus.windowDays }}">
                    </label>
                    <label>
                        <span>Reason</span>
                        <input type="text" name="reason" placeholder="Optional">
                    </label>
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                        <i data-lucide="save"></i> Save budget
                    </button>
                </form>
            </div>
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>AI spend cap</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/spend-cap">
                    <label>
                        <span>USD cap</span>
                        <input type="number" name="aiSpendCapUsd" min="0" step="0.01" value="{{ org.spendStatus.capUsd }}">
                    </label>
                    <label>
                        <span>Reason</span>
                        <input type="text" name="reason" placeholder="Optional">
                    </label>
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                        <i data-lucide="save"></i> Save spend cap
                    </button>
                </form>
            </div>
        </section>
    </div>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Recent changes</h2></div>
        <div class="rj-admin-panel__body">
            {% include "pages/admin/_audit-table.twig" with { auditLogs: org.auditLogs } %}
        </div>
    </section>

    <div class="rj-admin-detail-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Stripe billing</h2></div>
            <div class="rj-admin-panel__body">
                <dl class="rj-admin-kv">
                    <dt>Subscription</dt>
                    <dd>
                        {% if org.entitlement.stripeSubscriptionStatus %}
                            <span class="rj-badge {% if org.entitlement.stripeSubscriptionStatus in ['active', 'trialing'] %}rj-badge--success{% elseif org.entitlement.stripeSubscriptionStatus == 'past_due' %}rj-badge--warning{% else %}rj-badge--neutral{% endif %}">
                                <span class="rj-dot"></span>{{ org.entitlement.stripeSubscriptionStatus }}
                            </span>
                            {% if org.entitlement.stripeCancelAtPeriodEnd %}<span class="rj-admin-muted">cancels at period end</span>{% endif %}
                        {% else %}
                            <span class="rj-admin-muted">None</span>
                        {% endif %}
                    </dd>
                    {% if org.entitlement.stripeCurrentPeriodEnd %}
                        <dt>Period ends</dt>
                        <dd class="rj-num">{{ org.entitlement.stripeCurrentPeriodEnd|date("M j, Y") }}</dd>
                    {% endif %}
                    {% if org.entitlement.stripeCustomerId %}
                        <dt>Customer</dt>
                        <dd><a href="https://dashboard.stripe.com/customers/{{ org.entitlement.stripeCustomerId }}" target="_blank" rel="noopener" class="rj-admin-mono">{{ org.entitlement.stripeCustomerId }}</a></dd>
                    {% endif %}
                    {% if org.entitlement.stripeSubscriptionId %}
                        <dt>Subscription ID</dt>
                        <dd><a href="https://dashboard.stripe.com/subscriptions/{{ org.entitlement.stripeSubscriptionId }}" target="_blank" rel="noopener" class="rj-admin-mono">{{ org.entitlement.stripeSubscriptionId }}</a></dd>
                    {% endif %}
                </dl>
                {% if org.entitlement.stripeSubscriptionStatus and org.entitlement.stripeSubscriptionStatus not in ['canceled', 'incomplete_expired'] %}
                    <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/cancel-subscription">
                        <label>
                            <span>Reason</span>
                            <input type="text" name="reason" placeholder="Optional audit note">
                        </label>
                        <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit"
                                data-confirm="Cancel this subscription immediately? The organization drops to the free tier."
                                data-confirm-title="Cancel subscription"
                                data-confirm-confirm="Cancel subscription"
                                data-confirm-danger>
                            <i data-lucide="circle-x"></i> Cancel subscription
                        </button>
                    </form>
                {% endif %}
            </div>
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Suspension</h2></div>
            <div class="rj-admin-panel__body">
                {% if org.suspendedAt %}
                    <p><span class="rj-badge rj-badge--warning"><span class="rj-dot"></span>Suspended</span>
                        <span class="rj-admin-muted">since {{ org.suspendedAt|date("M j, Y") }}{% if org.suspendedReason %} — {{ org.suspendedReason }}{% endif %}</span></p>
                    <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/unsuspend">
                        <label>
                            <span>Reason</span>
                            <input type="text" name="reason" placeholder="Optional audit note">
                        </label>
                        <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">Unsuspend</button>
                    </form>
                {% else %}
                    <p class="rj-admin-muted">Suspending blocks tool access for every member (platform admins keep access). Sign-in still works.</p>
                    <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/suspend">
                        <label>
                            <span>Reason</span>
                            <input type="text" name="reason" placeholder="Shown in the audit log">
                        </label>
                        <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit"
                                data-confirm="Suspend {{ org.name|e('html_attr') }}? Tool access is blocked for every member (platform admins keep access)."
                                data-confirm-title="Suspend organization"
                                data-confirm-confirm="Suspend"
                                data-confirm-danger>
                            <i data-lucide="circle-alert"></i> Suspend organization
                        </button>
                    </form>
                {% endif %}
            </div>
        </section>
    </div>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Danger zone</h2></div>
        <div class="rj-admin-panel__body">
            <p class="rj-admin-muted">Deleting removes this organization from all access lists and navigation. Its data is retained but unreachable. You'll be asked to type the organization name to confirm.</p>
            <form class="rj-admin-form" method="post" action="/admin/orgs/{{ org.id }}/delete">
                <label>
                    <span>Reason</span>
                    <input type="text" name="reason" placeholder="Optional audit note">
                </label>
                <button class="rj-btn rj-btn--danger rj-btn--sm" type="submit"
                        data-confirm="Delete {{ org.name|e('html_attr') }}? It's removed from all access lists and navigation. This cannot be undone from the UI."
                        data-confirm-title="Delete organization"
                        data-confirm-confirm="Delete organization"
                        data-confirm-danger
                        data-confirm-match="{{ org.name|e('html_attr') }}"
                        data-confirm-match-name="confirmName"
                        data-confirm-match-label="Type the organization name to confirm">
                    <i data-lucide="trash-2"></i> Delete organization
                </button>
            </form>
        </div>
    </section>
{% endblock %}
