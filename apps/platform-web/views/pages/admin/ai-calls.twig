{% extends "layouts/app.twig" %}

{% block title %}AI calls — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        <h1>AI calls</h1>
        <p>Provider, model, token, duration, cache, and cost metadata for recent AI usage.</p>
    </div>

    <div class="rj-table-wrap">
        <table class="rj-table rj-admin-table">
            <thead>
                <tr>
                    <th>Call</th>
                    <th>Job</th>
                    <th>Provider / model</th>
                    <th>Tokens</th>
                    <th>Cost</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                {% for call in aiCalls %}
                    <tr>
                        <td>
                            <strong>{{ call.callType }}</strong>
                            {% if call.cacheHit %}
                                <br><span class="rj-badge rj-badge--info"><span class="rj-dot"></span>Cache hit</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if call.job %}
                                <a href="/admin/jobs/{{ call.job.id }}">{{ call.job.type }}</a>
                                <br><span class="rj-admin-muted rj-admin-mono">{{ call.job.id }}</span>
                                {% if call.job.org %}
                                    <br><span class="rj-admin-muted">{{ call.job.org.name }}</span>
                                {% endif %}
                            {% else %}
                                <span class="rj-admin-muted">No job</span>
                            {% endif %}
                        </td>
                        <td>{{ call.provider }}<br><span class="rj-admin-muted">{{ call.model }}</span></td>
                        <td>
                            <span class="rj-num">{{ call.totalTokens }}</span>
                            <br><span class="rj-admin-muted rj-num">{{ call.promptTokens }} in / {{ call.outputTokens }} out</span>
                        </td>
                        <td>
                            <span class="rj-num">${{ call.costUsdNumber|number_format(6, '.', ',') }}</span>
                            {% if call.durationMs %}
                                <br><span class="rj-admin-muted rj-num">{{ call.durationMs }}ms</span>
                            {% endif %}
                        </td>
                        <td class="rj-num">{{ call.createdAt|date("M j, Y g:ia") }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="rj-table__empty">No AI calls recorded yet.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
