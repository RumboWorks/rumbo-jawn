{% extends "layouts/app.twig" %}

{% block title %}{{ userDetail.email }} — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        {% include "pages/admin/_breadcrumbs.twig" with { sectionLabel: 'users', sectionHref: '/admin/users' } %}
        <h1>{{ userDetail.name ?? userDetail.email }}</h1>
        <p>{{ userDetail.email }} · <span class="rj-admin-mono">{{ userDetail.id }}</span></p>
    </div>

    <section class="rj-admin-metrics rj-admin-metrics--compact">
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Status</span>
            <strong>{{ userDetail.status }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Platform admin</span>
            <strong>{% if userDetail.isPlatformAdmin %}Yes{% else %}No{% endif %}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Jobs</span>
            <strong>{{ userDetail._count.jobs }}</strong>
        </div>
    </section>

    <div class="rj-admin-detail-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Profile</h2></div>
            <form class="rj-admin-form" method="post" action="/admin/users/{{ userDetail.id }}/profile">
                <label>
                    <span>First name</span>
                    <input type="text" name="firstName" value="{{ userDetail.firstName ?? '' }}" required>
                </label>
                <label>
                    <span>Last name</span>
                    <input type="text" name="lastName" value="{{ userDetail.lastName ?? '' }}" required>
                </label>
                <label>
                    <span>Email</span>
                    <input type="email" name="email" value="{{ userDetail.email }}" required>
                </label>
                <label>
                    <span>Status</span>
                    <select name="status">
                        {% for status in ['ACTIVE', 'SUSPENDED', 'DEACTIVATED'] %}
                            <option value="{{ status }}"{% if userDetail.status == status %} selected{% endif %}>{{ status }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>
                    <span>Status reason</span>
                    <input type="text" name="statusReason" value="{{ userDetail.statusReason ?? '' }}" placeholder="Required for operator clarity">
                </label>
                <label>
                    <span>Change reason</span>
                    <input type="text" name="reason" placeholder="Optional audit note">
                </label>
                <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                    <i data-lucide="save"></i> Save user
                </button>
            </form>
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Add organization membership</h2></div>
            <form class="rj-admin-form" method="post" action="/admin/users/{{ userDetail.id }}/memberships">
                <label>
                    <span>Organization</span>
                    <select name="orgId">
                        {% for org in userDetail.organizations %}
                            <option value="{{ org.id }}">{{ org.name }} · {{ org.organizationType|lower }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>
                    <span>Role</span>
                    <select name="role">
                        <option value="MEMBER">Member</option>
                        <option value="MANAGER">Manager</option>
                    </select>
                </label>
                <label>
                    <span>Reason</span>
                    <input type="text" name="reason" placeholder="Optional audit note">
                </label>
                <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">
                    <i data-lucide="plus"></i> Add membership
                </button>
            </form>
        </section>
    </div>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Organization memberships</h2></div>
        <div class="rj-table-wrap">
            <table class="rj-table rj-admin-table">
                <thead>
                    <tr>
                        <th>Organization</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for membership in userDetail.memberships %}
                        <tr>
                            <td><a href="/admin/orgs/{{ membership.org.id }}">{{ membership.org.name }}</a><br><span class="rj-admin-muted">{{ membership.org.slug }}</span></td>
                            <td>
                                <form class="rj-admin-inline-form" method="post" action="/admin/orgs/{{ membership.org.id }}/memberships/{{ membership.id }}/role">
                                    <select name="role">
                                        <option value="MEMBER"{% if membership.role == 'MEMBER' %} selected{% endif %}>Member</option>
                                        <option value="MANAGER"{% if membership.role == 'MANAGER' %} selected{% endif %}>Manager</option>
                                    </select>
                                    <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">Update</button>
                                </form>
                            </td>
                            <td class="rj-num">{{ membership.createdAt|date("M j, Y") }}</td>
                            <td>
                                <form method="post" action="/admin/users/{{ userDetail.id }}/memberships/{{ membership.id }}/remove">
                                    <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit">Remove</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="rj-table__empty">No memberships.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Grant tool access</h2></div>
        <form class="rj-admin-form" method="post" action="/admin/users/{{ userDetail.id }}/tool-grants">
            <label>
                <span>Organization</span>
                <select name="orgId">
                    {% for membership in userDetail.memberships %}
                        <option value="{{ membership.org.id }}">{{ membership.org.name }} · {{ membership.org.organizationType|lower }}</option>
                    {% else %}
                        <option value="" disabled>User has no organization memberships</option>
                    {% endfor %}
                </select>
            </label>
            <label>
                <span>Tool</span>
                <select name="tool">
                    {% for t in userDetail.tools %}
                        <option value="{{ t.key }}">{{ t.name }}{% if t.orgOpen %} (org-open){% endif %}</option>
                    {% endfor %}
                </select>
            </label>
            <label>
                <span>Role</span>
                <select name="role">
                    <option value="MEMBER">Member</option>
                    <option value="MANAGER">Manager</option>
                </select>
            </label>
            <label>
                <span>Reason</span>
                <input type="text" name="reason" placeholder="Optional audit note">
            </label>
            <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">
                <i data-lucide="key-round"></i> Grant access
            </button>
        </form>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Tool access</h2></div>
        <div class="rj-table-wrap">
            <table class="rj-table rj-admin-table">
                <thead>
                    <tr>
                        <th>Tool</th>
                        <th>Organization</th>
                        <th>Role</th>
                        <th>Granted</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for grant in userDetail.toolGrants %}
                        <tr>
                            <td>{{ grant.toolName }}<br><span class="rj-admin-muted rj-admin-mono">{{ grant.tool }}</span></td>
                            <td><a href="/admin/orgs/{{ grant.org.id }}">{{ grant.org.name }}</a></td>
                            <td>
                                <form class="rj-admin-inline-form" method="post" action="/admin/users/{{ userDetail.id }}/tool-grants">
                                    <input type="hidden" name="orgId" value="{{ grant.org.id }}">
                                    <input type="hidden" name="tool" value="{{ grant.tool }}">
                                    <select name="role">
                                        <option value="MEMBER"{% if grant.role == 'MEMBER' %} selected{% endif %}>Member</option>
                                        <option value="MANAGER"{% if grant.role == 'MANAGER' %} selected{% endif %}>Manager</option>
                                    </select>
                                    <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">Update</button>
                                </form>
                            </td>
                            <td class="rj-num">{{ grant.createdAt|date("M j, Y") }}</td>
                            <td>
                                <form method="post" action="/admin/users/{{ userDetail.id }}/tool-grants/{{ grant.id }}/remove">
                                    <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit">Revoke</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="rj-table__empty">No explicit tool grants. Access comes from org-open tools or platform-admin.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Recent jobs</h2></div>
        {% include "pages/admin/_jobs-table.twig" with { jobs: userDetail.recentJobs, compact: true } %}
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>User audit</h2></div>
        {% include "pages/admin/_audit-table.twig" with { auditLogs: userDetail.auditLogs } %}
    </section>
{% endblock %}
