{% extends "layouts/app.twig" %}

{% block title %}{{ pageHeading ?? 'Jobs' }} — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        <h1>{{ pageHeading ?? 'Jobs' }}</h1>
        <p>{{ pageDescription ?? 'Recent platform jobs across tools, organizations, and users.' }}</p>
    </div>

    <form class="rj-admin-filters" method="get" action="/admin/jobs">
        <label>
            <span>Type</span>
            <input type="text" name="type" value="{{ filters.type ?? '' }}" placeholder="slu.analysis">
        </label>
        <label>
            <span>Status</span>
            <select name="status">
                <option value="">Any status</option>
                {% for status in ['PENDING', 'RUNNING', 'DONE', 'FAILED', 'CANCELLED'] %}
                    <option value="{{ status }}"{% if filters.status == status %} selected{% endif %}>{{ status }}</option>
                {% endfor %}
            </select>
        </label>
        <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">
            <i data-lucide="filter"></i> Filter
        </button>
        {% if filters.type or filters.status %}
            <a class="rj-btn rj-btn--ghost rj-btn--sm" href="/admin/jobs">Clear</a>
        {% endif %}
    </form>

    {% include "pages/admin/_jobs-table.twig" with { jobs: jobs, compact: false } %}
{% endblock %}
