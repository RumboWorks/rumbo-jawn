{% extends "layouts/app.twig" %}

{% block title %}{{ partner.name }} — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        {% include "pages/admin/_breadcrumbs.twig" with { sectionLabel: 'partners', sectionHref: '/admin/partners' } %}
        <h1>{{ partner.name }}</h1>
        <p><span class="rj-admin-mono">{{ partner.publicId }}</span></p>
    </div>

    {% include "pages/admin/_flash.twig" %}

    <div class="rj-admin-detail-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Details</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/admin/partners/{{ partner.id }}">
                    <label>
                        <span>Name</span>
                        <input type="text" name="name" value="{{ partner.name }}" required>
                    </label>
                    <label>
                        <span>Support email</span>
                        <input type="email" name="supportEmail" value="{{ partner.supportEmail ?? '' }}">
                    </label>
                    <label>
                        <span>Reason</span>
                        <input type="text" name="reason" placeholder="Optional audit note">
                    </label>
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                        <i data-lucide="save"></i> Save partner
                    </button>
                </form>
            </div>
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Add manager</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/admin/partners/{{ partner.id }}/members">
                    <label>
                        <span>Email</span>
                        <input type="email" name="email" placeholder="existing-user@example.org" required>
                    </label>
                    <p class="rj-admin-muted">The user must already have a Rumbo account.</p>
                    <label>
                        <span>Reason</span>
                        <input type="text" name="reason" placeholder="Optional audit note">
                    </label>
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                        <i data-lucide="plus"></i> Add manager
                    </button>
                </form>
            </div>
        </section>
    </div>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Managers</h2></div>
        <div class="rj-admin-panel__body">
            <div class="rj-table-wrap">
                <table class="rj-table rj-admin-table">
                    <thead>
                        <tr>
                            <th>Manager</th>
                            <th>Added</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for membership in partner.memberships %}
                            <tr>
                                <td>
                                    {{ membership.user.email }}
                                    <br><span class="rj-admin-muted">{{ membership.user.name }}</span>
                                </td>
                                <td class="rj-num">{{ membership.createdAt|date("M j, Y") }}</td>
                                <td>
                                    <form method="post" action="/admin/partners/{{ partner.id }}/members/{{ membership.id }}/remove">
                                        <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="3" class="rj-table__empty">No managers yet.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Managed organizations</h2></div>
        <div class="rj-admin-panel__body">
            <form class="rj-admin-form" method="post" action="/admin/partners/{{ partner.id }}/org-access">
                <label>
                    <span>Organization</span>
                    <select name="orgId" required>
                        {% for org in orgOptions %}
                            <option value="{{ org.id }}">{{ org.name }} ({{ org.slug }})</option>
                        {% endfor %}
                    </select>
                </label>
                <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                    <i data-lucide="plus"></i> Grant access
                </button>
            </form>

            <div class="rj-table-wrap">
                <table class="rj-table rj-admin-table">
                    <thead>
                        <tr>
                            <th>Organization</th>
                            <th>Tier</th>
                            <th>Members</th>
                            <th>Since</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for access in partner.orgAccesses %}
                            <tr>
                                <td>
                                    <a href="/admin/orgs/{{ access.org.id }}"><strong>{{ access.org.name }}</strong></a>
                                    <br><span class="rj-admin-muted">{{ access.org.slug }}</span>
                                </td>
                                <td>
                                    {% if access.org.entitlement %}
                                        {{ access.org.entitlement.tier.name }}
                                    {% else %}
                                        <span class="rj-admin-muted">No tier</span>
                                    {% endif %}
                                </td>
                                <td class="rj-num">{{ access.org._count.memberships }}</td>
                                <td class="rj-num">{{ access.createdAt|date("M j, Y") }}</td>
                                <td>
                                    <form method="post" action="/admin/partners/{{ partner.id }}/org-access/{{ access.id }}/remove">
                                        <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="rj-table__empty">No managed organizations.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
