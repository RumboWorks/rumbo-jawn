{% extends "layouts/app.twig" %}

{% block title %}Eval runs — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        {% include "pages/admin/_breadcrumbs.twig" with { sectionLabel: 'eval runs', sectionHref: '/admin/eval' } %}
        <h1>Eval runs</h1>
        <p>Every run across all organizations. "Move to trash" hides a run everywhere and is reversible for {{ purgeAfterDays }} days, after which it is permanently deleted with all its data.</p>
    </div>

    {% include "pages/admin/_flash.twig" %}

    <div class="rj-table-wrap">
        <table class="rj-table rj-admin-table">
            <thead>
                <tr>
                    <th>Evaluation</th>
                    <th>Organization</th>
                    <th>Status</th>
                    <th>Responses</th>
                    <th>Ratings</th>
                    <th>Reviewers</th>
                    <th>Launched</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for run in runs %}
                    <tr>
                        <td>
                            <strong>{{ run.eval.title }}</strong>
                            <br><span class="rj-admin-muted">Run {{ run.runNumber }}</span>
                        </td>
                        <td>
                            {% if run.org %}
                                {{ run.org.name }}
                                <br><span class="rj-admin-muted">{{ run.org.slug }}</span>
                            {% else %}
                                <span class="rj-admin-muted">Unknown</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="eval-status eval-status--{{ run.status|lower }}">{{ run.status|replace({'_': ' '})|lower }}</span>
                        </td>
                        <td class="rj-num">{{ run._count.responses }}</td>
                        <td class="rj-num">{{ run._count.ratings }}</td>
                        <td class="rj-num">{{ run._count.reviewAssignments }}</td>
                        <td class="rj-num">{{ run.createdAt|date("M j, Y") }}</td>
                        <td>
                            <form method="post" action="/admin/eval/runs/{{ run.id }}/trash">
                                <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit"
                                        data-confirm="Move this run to the trash? It disappears from the tool and can be restored for {{ purgeAfterDays }} days."
                                        data-confirm-title="Move run to trash"
                                        data-confirm-confirm="Move to trash"><i data-lucide="trash-2"></i> Move to trash</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="8" class="rj-table__empty">No eval runs.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Trash</h2></div>
        <div class="rj-admin-panel__body">
            <p class="rj-admin-muted">Trashed runs are hidden from the tool and permanently deleted {{ purgeAfterDays }} days after trashing. If a trashed run was its evaluation's only run, restoring it brings the evaluation back too.</p>
            {% if trashedRuns is empty %}
                <p class="rj-admin-empty">The trash is empty.</p>
            {% else %}
                <div class="rj-table-wrap">
                    <table class="rj-table rj-admin-table" data-no-sort>
                        <thead>
                            <tr>
                                <th>Evaluation</th>
                                <th>Organization</th>
                                <th>Trashed</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for run in trashedRuns %}
                                <tr>
                                    <td>
                                        <strong>{{ run.eval.title }}</strong>
                                        <br><span class="rj-admin-muted">Run {{ run.runNumber }}</span>
                                    </td>
                                    <td>
                                        {% if run.org %}{{ run.org.name }}{% else %}<span class="rj-admin-muted">Unknown</span>{% endif %}
                                    </td>
                                    <td class="rj-num">{{ run.deletedAt|date("M j, Y") }}</td>
                                    <td>
                                        <form method="post" action="/admin/eval/runs/{{ run.id }}/restore" style="display:inline">
                                            <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">Restore</button>
                                        </form>
                                        <form method="post" action="/admin/eval/runs/{{ run.id }}/purge" style="display:inline">
                                            <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit"
                                                    data-confirm="Permanently delete this run and all its data? This cannot be undone."
                                                    data-confirm-title="Delete run permanently"
                                                    data-confirm-confirm="Delete now"
                                                    data-confirm-danger><i data-lucide="trash-2"></i> Delete now</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
