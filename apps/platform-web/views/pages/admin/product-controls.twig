{% extends "layouts/app.twig" %}

{% block title %}Product controls — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        {% include "pages/admin/_breadcrumbs.twig" with { sectionLabel: 'product controls', sectionHref: '/admin/product-controls' } %}
        <h1>Product controls</h1>
        <p>Tier Stripe pricing, feature flags, and AI model/provider settings. Changes are audit-logged.</p>
    </div>

    {% if flash_success %}
        <div class="rj-alert rj-alert--success"><i data-lucide="check-circle"></i><div class="rj-alert__body">{{ flash_success }}</div></div>
    {% endif %}
    {% if flash_error %}
        <div class="rj-alert rj-alert--danger"><i data-lucide="circle-alert"></i><div class="rj-alert__body">{{ flash_error }}</div></div>
    {% endif %}

    {% set activeTab = tab %}

    <div class="rj-segmented" style="max-width:520px;margin-bottom:var(--rj-space-5)">
        <span class="rj-segmented__indicator" aria-hidden="true"></span>
        <a href="?tab=tiers"     class="rj-segmented__btn {% if activeTab == 'tiers' %}is-active{% endif %}">Tiers</a>
        <a href="?tab=ai-models" class="rj-segmented__btn {% if activeTab == 'ai-models' %}is-active{% endif %}">AI models</a>
        <a href="?tab=flags"     class="rj-segmented__btn {% if activeTab == 'flags' %}is-active{% endif %}">Feature flags</a>
        <a href="?tab=audit"     class="rj-segmented__btn {% if activeTab == 'audit' %}is-active{% endif %}">Recent changes</a>
    </div>

    {# ── Tiers ── #}
    {% if activeTab == 'tiers' %}
    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Product tiers — Stripe pricing</h2></div>
        <div class="rj-admin-panel__body">
            <p class="rj-admin-muted" style="margin-bottom:var(--rj-space-4)">Paste Price IDs from your Stripe dashboard. Each paid tier needs one monthly and one annual Price. Free tier is always free.</p>
            <div class="rj-table-wrap">
                <table class="rj-table rj-admin-table">
                    <thead>
                        <tr>
                            <th>Tier</th>
                            <th>Monthly price ID</th>
                            <th>USD/mo</th>
                            <th>Annual price ID</th>
                            <th>USD/yr</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tier in controls.tiers %}
                        <tr>
                            <form method="post" action="/admin/product-controls/tiers/{{ tier.id }}">
                            <td>
                                <strong>{{ tier.name }}</strong>
                                <br><span class="rj-admin-muted rj-admin-mono">{{ tier.key }}</span>
                            </td>
                            <td>
                                <input class="rj-input rj-input--sm" style="width:100%;min-width:180px"
                                    type="text" name="stripePriceId"
                                    value="{{ tier.stripePriceId ?? '' }}"
                                    placeholder="price_…"
                                    {% if tier.key == 'free' %}disabled{% endif %}>
                            </td>
                            <td>
                                <input class="rj-input rj-input--sm" style="width:80px"
                                    type="number" name="priceUsdMonthly" min="0" step="0.01"
                                    value="{{ tier.priceUsdMonthly ?? '' }}"
                                    placeholder="0.00"
                                    {% if tier.key == 'free' %}disabled{% endif %}>
                            </td>
                            <td>
                                <input class="rj-input rj-input--sm" style="width:100%;min-width:180px"
                                    type="text" name="stripePriceIdAnnual"
                                    value="{{ tier.stripePriceIdAnnual ?? '' }}"
                                    placeholder="price_…"
                                    {% if tier.key == 'free' %}disabled{% endif %}>
                            </td>
                            <td>
                                <input class="rj-input rj-input--sm" style="width:80px"
                                    type="number" name="priceUsdAnnual" min="0" step="0.01"
                                    value="{{ tier.priceUsdAnnual ?? '' }}"
                                    placeholder="0.00"
                                    {% if tier.key == 'free' %}disabled{% endif %}>
                            </td>
                            <td>
                                {% if tier.key != 'free' %}
                                    <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">Save</button>
                                {% else %}
                                    <span class="rj-admin-muted">—</span>
                                {% endif %}
                            </td>
                            </form>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
    {% endif %}

    {# ── AI models ── #}
    {% if activeTab == 'ai-models' %}
    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header">
            <h2>AI model config</h2>
            <a class="rj-btn rj-btn--secondary rj-btn--sm" href="/admin/product-controls/ai-model-config/new">
                <i data-lucide="plus"></i> Add
            </a>
        </div>
        <div class="rj-admin-panel__body">
            <div class="rj-table-wrap">
                <table class="rj-table rj-admin-table">
                    <thead>
                        <tr>
                            <th>Tool</th>
                            <th>Call type</th>
                            <th>Provider / model</th>
                            <th>Scope</th>
                            <th>Enabled</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for config in controls.aiModelConfigs %}
                            <tr>
                                <td>{{ config.tool }}</td>
                                <td><a href="/admin/product-controls/ai-model-config/{{ config.id }}">{{ config.callType }}</a></td>
                                <td>{{ config.provider }}<br><span class="rj-admin-muted">{{ config.model }}</span></td>
                                <td>{{ config.scope }}{% if config.scopeId %}<br><span class="rj-admin-muted rj-admin-mono">{{ config.scopeId }}</span>{% endif %}</td>
                                <td>{% if config.enabled %}Yes{% else %}No{% endif %}</td>
                                <td><a class="rj-btn rj-btn--ghost rj-btn--sm" href="/admin/product-controls/ai-model-config/{{ config.id }}">Edit</a></td>
                            </tr>
                        {% else %}
                            <tr><td colspan="6" class="rj-table__empty">No model config found.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
    {% endif %}

    {# ── Feature flags ── #}
    {% if activeTab == 'flags' %}
    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header">
            <h2>Feature flags</h2>
            <a class="rj-btn rj-btn--secondary rj-btn--sm" href="/admin/product-controls/feature-flags/new">
                <i data-lucide="plus"></i> Add
            </a>
        </div>
        <div class="rj-admin-panel__body">
            <div class="rj-table-wrap">
                <table class="rj-table rj-admin-table">
                    <thead>
                        <tr>
                            <th>Key</th>
                            <th>Scope</th>
                            <th>Tool</th>
                            <th>Enabled</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for flag in controls.featureFlags %}
                            <tr>
                                <td><a href="/admin/product-controls/feature-flags/{{ flag.id }}">{{ flag.key }}</a></td>
                                <td>{{ flag.scope }}{% if flag.scopeId %}<br><span class="rj-admin-muted rj-admin-mono">{{ flag.scopeId }}</span>{% endif %}</td>
                                <td>{% if flag.tool %}{{ flag.tool }}{% else %}<span class="rj-admin-muted">Any</span>{% endif %}</td>
                                <td>{% if flag.enabled %}Yes{% else %}No{% endif %}</td>
                                <td><a class="rj-btn rj-btn--ghost rj-btn--sm" href="/admin/product-controls/feature-flags/{{ flag.id }}">Edit</a></td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="rj-table__empty">No feature flags found.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
    {% endif %}

    {# ── Recent changes ── #}
    {% if activeTab == 'audit' %}
    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Recent product-control changes</h2></div>
        <div class="rj-admin-panel__body">
            {% include "pages/admin/_audit-table.twig" with { auditLogs: controls.auditLogs } %}
        </div>
    </section>
    {% endif %}

{% endblock %}
