{% extends "layouts/app.twig" %}

{% block title %}Organizations — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header rj-page-header--with-action">
        <div class="rj-page-header__text">
            {% include "pages/admin/_breadcrumbs.twig" with { sectionLabel: 'organizations', sectionHref: '/admin/orgs' } %}
            <h1>Organizations</h1>
            <p>Tenant records, membership counts, partner access, and tool activity.</p>
        </div>
        <a href="/admin/orgs/new" class="rj-btn rj-btn--primary rj-btn--sm rj-page-header__action">
            <i data-lucide="plus"></i> Add organization
        </a>
    </div>

    {% include "pages/admin/_flash.twig" %}

    <div class="rj-table-wrap">
        <table class="rj-table rj-admin-table">
            <thead>
                <tr>
                    <th>Organization</th>
                    <th>Type</th>
                    <th>Tier / budget</th>
                    <th>Billing</th>
                    <th>Partner access</th>
                    <th>Jobs</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                {% for org in orgs %}
                    <tr>
                        <td>
                            <a href="/admin/orgs/{{ org.id }}"><strong>{{ org.name }}</strong></a>
                            <br><span class="rj-admin-muted">{{ org.slug }}</span>
                            <br><span class="rj-admin-muted rj-admin-mono">{{ org.publicId }}</span>
                        </td>
                        <td>
                            {% if org.organizationType == 'SOLO' %}
                                <span class="rj-badge rj-badge--neutral"><span class="rj-dot"></span>Solo</span>
                            {% else %}
                                <span class="rj-badge rj-badge--pine"><span class="rj-dot"></span>{{ org.organizationType|lower }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if org.entitlement %}
                                <strong>{{ org.entitlement.tier.name }}</strong>
                            {% else %}
                                <span class="rj-admin-muted">No tier</span>
                            {% endif %}
                            {% if org.sluBudgetStatus %}
                                <br>
                                {% if org.sluBudgetStatus.overBudget %}
                                    <span class="rj-badge rj-badge--warning"><span class="rj-dot"></span>Over budget</span>
                                {% else %}
                                    <span class="rj-admin-muted">SLU budget</span>
                                {% endif %}
                                <br><span class="rj-admin-muted rj-num">{{ org.sluBudgetStatus.used }} / {{ org.sluBudgetStatus.limit }} runs · {{ org.sluBudgetStatus.windowDays }}d</span>
                            {% endif %}
                            {% if org.spendStatus %}
                                <br><span class="rj-admin-muted rj-num">${{ org.spendStatus.spentUsd|number_format(4, '.', ',') }} / ${{ org.spendStatus.capUsd|number_format(2, '.', ',') }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if org.entitlement and org.entitlement.billingResponsibleUser %}
                                {{ org.entitlement.billingResponsibleUser.email }}
                            {% elseif org.entitlement and org.entitlement.billingResponsibleMembership %}
                                {{ org.entitlement.billingResponsibleMembership.user.email }}
                            {% else %}
                                <span class="rj-admin-muted">Unassigned</span>
                            {% endif %}
                            <br><span class="rj-admin-muted">{{ org.memberships|length }} members</span>
                            {% for membership in org.memberships|slice(0, 3) %}
                                <br><span class="rj-admin-muted">{{ membership.user.email }} · {{ membership.role|lower }}</span>
                            {% endfor %}
                        </td>
                        <td>
                            {% if org.partnerAccesses|length == 0 %}
                                <span class="rj-admin-muted">None</span>
                            {% else %}
                                {% for access in org.partnerAccesses %}
                                    <div>{{ access.partnerAccount.name }}</div>
                                {% endfor %}
                            {% endif %}
                        </td>
                        <td>
                            <span class="rj-num">{{ org._count.jobs }}</span>
                            {% if org._count.approvedDomains %}
                                <br><span class="rj-admin-muted">{{ org._count.approvedDomains }} domains</span>
                            {% endif %}
                        </td>
                        <td class="rj-num">{{ org.createdAt|date("M j, Y") }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="7" class="rj-table__empty">No organizations found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
