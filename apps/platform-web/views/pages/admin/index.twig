{% extends "layouts/app.twig" %}

{% block title %}Admin — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        {% include "pages/admin/_breadcrumbs.twig" %}
        <h1>Admin</h1>
        <p>Central platform visibility for users, organizations, jobs, AI calls, costs, and tool runs.</p>
    </div>

    <section class="rj-admin-metrics" aria-label="Platform metrics">
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Users</span>
            <strong>{{ dashboard.metrics.userCount }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Organizations</span>
            <strong>{{ dashboard.metrics.orgCount }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Jobs</span>
            <strong>{{ dashboard.metrics.jobCount }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Failures</span>
            <strong>{{ dashboard.metrics.failedJobCount }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">AI calls</span>
            <strong>{{ dashboard.metrics.aiCallCount }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">AI cost</span>
            <strong>${{ dashboard.metrics.aiCostUsd|number_format(4, '.', ',') }}</strong>
        </div>
    </section>

    <div class="rj-admin-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header">
                <h2>Recent jobs</h2>
                <a href="/admin/jobs">View all</a>
            </div>
            {% include "pages/admin/_jobs-table.twig" with { jobs: dashboard.recentJobs, compact: true } %}
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header">
                <h2>Recent failures</h2>
                <a href="/admin/failures">View all</a>
            </div>
            {% include "pages/admin/_jobs-table.twig" with { jobs: dashboard.recentFailures, compact: true } %}
        </section>
    </div>

    <div class="rj-admin-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header">
                <h2>Sounds Like Us runs</h2>
                <a href="/admin/sounds-like-us">View all</a>
            </div>
            {% include "pages/admin/_jobs-table.twig" with { jobs: dashboard.recentSluRuns, compact: true } %}
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header">
                <h2>Recent AI calls</h2>
                <a href="/admin/ai-calls">View all</a>
            </div>
            {% if dashboard.recentAiCalls|length == 0 %}
                <p class="rj-admin-empty">No AI calls recorded yet.</p>
            {% else %}
                <div class="rj-table-wrap">
                    <table class="rj-table rj-admin-table">
                        <thead>
                            <tr>
                                <th>Call</th>
                                <th>Model</th>
                                <th>Tokens</th>
                                <th>Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for call in dashboard.recentAiCalls %}
                                <tr>
                                    <td>
                                        <strong>{{ call.callType }}</strong>
                                        {% if call.job %}
                                            <br><a href="/admin/jobs/{{ call.job.id }}" class="rj-admin-muted">{{ call.job.type }}</a>
                                        {% endif %}
                                    </td>
                                    <td>{{ call.provider }} / {{ call.model }}</td>
                                    <td class="rj-num">{{ call.totalTokens }}</td>
                                    <td class="rj-num">${{ call.costUsd|number_format(6, '.', ',') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </section>
    </div>
{% endblock %}
