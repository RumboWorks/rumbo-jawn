{% extends "layouts/app.twig" %}

{% block title %}Users — Rumbo Admin{% endblock %}

{% block sidebar %}
    {% include "pages/admin/_sidebar.twig" %}
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        {% include "pages/admin/_breadcrumbs.twig" with { sectionLabel: 'users', sectionHref: '/admin/users' } %}
        <h1>Users</h1>
        <p>Platform identities and their organization or partner relationships.</p>
    </div>

    <form class="rj-admin-filters" method="get" action="/admin/users">
        <label>
            <span>Search</span>
            <input type="search" name="q" value="{{ q ?? '' }}" placeholder="email or name">
        </label>
        <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">
            <i data-lucide="filter"></i> Search
        </button>
        {% if q %}
            <a class="rj-btn rj-btn--ghost rj-btn--sm" href="/admin/users">Clear</a>
        {% endif %}
    </form>

    {# baseQuery carries q + sort + dir into pager links; page is appended per-link. #}
    {% set _params = [] %}
    {% if q %}{% set _params = _params|merge(['q=' ~ q|url_encode]) %}{% endif %}
    {% if sort %}{% set _params = _params|merge(['sort=' ~ sort, 'dir=' ~ dir]) %}{% endif %}
    {% set baseQuery = _params is empty ? '' : _params|join('&') ~ '&' %}
    {% set pagerArgs = { total, page, pageCount, pageSize, shown: users|length, baseQuery, label: 'users', q } %}

    {% include "pages/admin/_list-pager.twig" with pagerArgs %}

    {# Server-managed list: data-server-table opts out of the client-side filter/
       count (which would only see this page's rows); sortable headers carry a
       data-sort-key and re-query the server via ?sort/&dir. #}
    <div class="rj-table-wrap" data-server-table>
        <table class="rj-table rj-admin-table">
            <thead>
                <tr>
                    <th class="rj-table__sort-head{% if sort == 'email' %} is-sort-active is-sort-{{ dir }}{% endif %}" data-sort-key="email">User</th>
                    <th class="rj-table__sort-head{% if sort == 'isPlatformAdmin' %} is-sort-active is-sort-{{ dir }}{% endif %}" data-sort-key="isPlatformAdmin">Platform</th>
                    <th>Organizations</th>
                    <th>Partners</th>
                    <th class="rj-table__sort-head{% if sort == 'jobs' %} is-sort-active is-sort-{{ dir }}{% endif %}" data-sort-key="jobs" data-sort-default="desc">Jobs</th>
                    <th class="rj-table__sort-head{% if sort == 'createdAt' %} is-sort-active is-sort-{{ dir }}{% endif %}" data-sort-key="createdAt" data-sort-default="desc">Created</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>
                            <a href="/admin/users/{{ user.id }}"><strong>{{ user.name ?? user.email }}</strong></a>
                            <br><span class="rj-admin-muted">{{ user.email }}</span>
                        </td>
                        <td>
                            {% if user.isPlatformAdmin %}
                                <span class="rj-badge rj-badge--pine"><span class="rj-dot"></span>Admin</span>
                            {% else %}
                                <span class="rj-badge rj-badge--neutral"><span class="rj-dot"></span>User</span>
                            {% endif %}
                            {% if user.status and user.status != 'ACTIVE' %}
                                <br><span class="rj-badge rj-badge--warning"><span class="rj-dot"></span>{{ user.status|lower }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if user.memberships|length == 0 %}
                                <span class="rj-admin-muted">None</span>
                            {% else %}
                                {% for membership in user.memberships %}
                                    <div>{{ membership.org.name }} <span class="rj-admin-muted">{{ membership.role|lower }}</span></div>
                                {% endfor %}
                            {% endif %}
                        </td>
                        <td>
                            {% if user.partnerMemberships|length == 0 %}
                                <span class="rj-admin-muted">None</span>
                            {% else %}
                                {% for membership in user.partnerMemberships %}
                                    <div>{{ membership.partnerAccount.name }} <span class="rj-admin-muted">{{ membership.role|lower }}</span></div>
                                {% endfor %}
                            {% endif %}
                        </td>
                        <td class="rj-num">{{ user._count.jobs }}</td>
                        <td class="rj-num">{{ user.createdAt|date("M j, Y") }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="rj-table__empty">No users found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% include "pages/admin/_list-pager.twig" with pagerArgs %}
{% endblock %}
