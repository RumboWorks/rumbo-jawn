{% extends "layouts/base.twig" %}

{% block title %}{{ title }} — Sounds Like Us{% endblock %}

{% block content %}
<div class="rj-container slu-page">

    <div class="slu-job-header">
        <p class="rj-eyebrow">Sounds Like Us</p>
        <h1 class="rj-h1">Analyzing organization</h1>
        {% if job.url %}
        <p class="rj-caption slu-job-url">
            <i data-lucide="globe"></i> {{ job.url }}
        </p>
        {% endif %}
    </div>

    <div class="slu-status-card rj-card rj-card--pad" id="slu-status-card"
         data-job-id="{{ job.id }}"
         data-status="{{ job.status }}">

        {% if job.status == 'DONE' %}
            <div class="slu-status slu-status--done">
                <i data-lucide="check-circle-2"></i>
                <span>Analysis complete</span>
            </div>
            <a href="/slu/jobs/{{ job.id }}/workbench" class="rj-btn rj-btn--primary rj-btn--lg slu-result-btn">
                <i data-lucide="sparkles"></i> View guidance
            </a>

        {% elseif job.status == 'FAILED' %}
            <div class="slu-status slu-status--failed">
                <i data-lucide="x-circle"></i>
                <span>Analysis failed</span>
            </div>
            {% if job.errorMsg %}
            <p class="rj-body-sm slu-error-msg">{{ job.errorMsg }}</p>
            {% endif %}
            <a href="/slu" class="rj-btn rj-btn--secondary">Try again</a>

        {% else %}
            <div class="slu-status slu-status--running" id="slu-status-indicator">
                <i data-lucide="loader"></i>
                <span id="slu-status-text">
                    {% if job.status == 'PENDING' %}Queued — waiting for worker…
                    {% else %}Crawling and analyzing…{% endif %}
                </span>
            </div>
            <div class="slu-progress-steps" id="slu-progress-steps">
                <div class="slu-step" id="step-crawl">
                    <i data-lucide="globe"></i> Crawling pages
                </div>
                <div class="slu-step" id="step-analyze">
                    <i data-lucide="brain"></i> Analyzing voice and tone
                </div>
                <div class="slu-step slu-step--has-bar" id="step-guidance">
                    <div class="slu-step__row">
                        <i data-lucide="file-text"></i>
                        <span id="step-guidance-label">Generating guidance</span>
                    </div>
                    <div class="slu-step__bar-track" id="step-guidance-track">
                        <div class="slu-step__bar-fill" id="step-guidance-bar"></div>
                    </div>
                </div>
            </div>
        {% endif %}

    </div>

</div>

<script type="module">
const card   = document.getElementById('slu-status-card');
const jobId  = card?.dataset.jobId;
let   status = card?.dataset.status;

if (jobId && (status === 'PENDING' || status === 'RUNNING')) {
    const steps     = ['step-crawl', 'step-analyze', 'step-guidance'];
    const barEl     = document.getElementById('step-guidance-bar');
    const trackEl   = document.getElementById('step-guidance-track');
    const labelEl   = document.getElementById('step-guidance-label');
    let   pollCount = 0;

    // Bar phases while generating (each phase is one poll tick = ~3s).
    // Values are % widths. Cap at 85 until DONE, then fill to 100.
    const BAR_PHASES = [12, 28, 42, 55, 65, 73, 79, 83, 85];
    let   barPhase   = 0;

    const setStep = (n) => {
        steps.forEach((id, i) => {
            const el = document.getElementById(id);
            if (el) el.classList.toggle('is-active', i <= n);
        });
    };

    const setBar = (pct, instant = false) => {
        if (!barEl) return;
        if (instant) barEl.style.transition = 'none';
        barEl.style.width = pct + '%';
        if (instant) requestAnimationFrame(() => { barEl.style.transition = ''; });
    };

    const advanceBar = () => {
        const pct = BAR_PHASES[Math.min(barPhase, BAR_PHASES.length - 1)];
        setBar(pct);
        barPhase++;

        // Update the label text to reflect sub-stages
        if (labelEl) {
            if (barPhase <= 2) labelEl.textContent = 'Building guidance profile…';
            else if (barPhase <= 4) labelEl.textContent = 'Identifying vocabulary and tone…';
            else if (barPhase <= 6) labelEl.textContent = 'Writing guidance blocks…';
            else labelEl.textContent = 'Assembling guidance…';
        }
    };

    setStep(-1);

    const poll = async () => {
        try {
            const res  = await fetch(`/slu/jobs/${jobId}/status`);
            const data = await res.json();
            status = data.status;
            pollCount++;

            if (status === 'RUNNING') {
                const stepN = Math.min(Math.floor(pollCount / 3), steps.length - 1);
                setStep(stepN);

                // Once the guidance step is active, start advancing the bar
                if (stepN === steps.length - 1) {
                    advanceBar();
                }
            }

            if (status === 'DONE') {
                setStep(steps.length - 1);
                setBar(100);
                if (labelEl) labelEl.textContent = 'Guidance ready';
                setTimeout(() => {
                    window.location.href = `/slu/jobs/${jobId}/workbench`;
                }, 600);
            } else if (status === 'FAILED') {
                window.location.reload();
            } else {
                setTimeout(poll, 3000);
            }
        } catch {
            setTimeout(poll, 5000);
        }
    };

    setTimeout(poll, 3000);
}
</script>
{% endblock %}
