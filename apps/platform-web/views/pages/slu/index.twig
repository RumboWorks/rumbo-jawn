{% extends currentUser ? "layouts/app.twig" : "layouts/base.twig" %}

{% block title %}Sounds Like Us — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/slu/_sidebar.twig" with { active: 'analyze' } %}
{% endblock %}

{% block content %}
<div class="{% if not currentUser %}rj-container {% endif %}slu-page">

    <div class="slu-hero">
        <p class="rj-eyebrow">Sounds Like Us</p>
        <h1 class="rj-h1">Generate writing guidance from your organization's voice</h1>
        <p class="rj-lead">Enter a public website URL. We'll analyze the content and produce reusable writing guidance your team or AI tools can use to write in your organization's voice.</p>
    </div>

    <div class="slu-analyze-card rj-card rj-card--pad">
        {% if budgetStatus and budgetStatus.overBudget %}
            <div class="slu-budget-indicator" aria-label="Usage budget status">
                <span class="rj-badge rj-badge--warning"><span class="rj-dot"></span>Over budget</span>
                <span class="rj-caption">{{ budgetStatus.used }} of {{ budgetStatus.limit }} runs used in {{ budgetStatus.windowDays }} days. You can still continue.</span>
            </div>
        {% endif %}
        <form method="POST" action="/slu/analyze" class="slu-url-form">
            <div class="rj-field">
                <label class="rj-label rj-label--required" for="url">Organization website URL</label>
                <input
                    class="rj-input slu-url-input"
                    type="url"
                    id="url"
                    name="url"
                    value="{{ pendingUrl }}"
                    placeholder="https://example.org"
                    required
                    autocomplete="off"
                    spellcheck="false"
                >
                <span class="rj-hint">Use a public URL. Do not submit pages containing confidential or sensitive information.</span>
            </div>

            <div class="slu-privacy-notice rj-alert rj-alert--info">
                <i data-lucide="info"></i>
                <div>Content from submitted URLs may be sent to AI providers (OpenAI, Anthropic, DeepSeek) for analysis.</div>
            </div>

            <button type="submit" class="rj-btn rj-btn--primary rj-btn--lg">
                <i data-lucide="sparkles"></i>
                Analyze this organization
            </button>
        </form>
    </div>

</div>
{% endblock %}
