{# Password row: masked display + inline change form (local-password accounts
   only). Needs `account` in scope. #}
<div class="rj-item" data-inline-edit>
    <div class="rj-item__display" data-edit-display>
        <div class="rj-item__main">
            <div class="rj-item__title">Password</div>
            <div class="rj-item__meta">
                {% if account.hasPassword %}••••••••{% else %}This account signs in with {{ account.authProviders|join(', ') }}.{% endif %}
            </div>
        </div>
        {% if account.hasPassword %}
            <div class="rj-item__actions">
                <button type="button" class="rj-btn rj-btn--ghost rj-btn--sm" data-edit-start>
                    <i data-lucide="pencil"></i> Change
                </button>
            </div>
        {% endif %}
    </div>
    {% if account.hasPassword %}
        <form class="rj-item__edit" method="post" action="/account/password" data-edit-form hidden>
            <label>
                <span>Current password</span>
                <input type="password" name="currentPassword" autocomplete="current-password" required>
            </label>
            <label>
                <span>New password</span>
                <input type="password" name="newPassword" autocomplete="new-password" minlength="8" required>
            </label>
            <div class="rj-item__edit-actions">
                <button type="submit" class="rj-btn rj-btn--secondary rj-btn--sm"><i data-lucide="save"></i> Save</button>
                <button type="button" class="rj-btn rj-btn--ghost rj-btn--sm" data-edit-cancel>Cancel</button>
            </div>
        </form>
    {% endif %}
</div>
