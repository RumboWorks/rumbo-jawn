{% extends "layouts/app.twig" %}

{% block title %}{{ org.name }} members — Rumbo{% endblock %}

{% block sidebar %}
    <span class="rj-sidebar__label">Account</span>
    <div class="rj-sidebar__section">
        <a href="/account" class="rj-sidebar__link">
            <i data-lucide="user"></i> Profile
        </a>
        <a href="/account/orgs/{{ org.id }}/members" class="rj-sidebar__link is-active">
            <i data-lucide="users"></i> {{ org.name }}
        </a>
    </div>
{% endblock %}

{% block content %}
    <div class="rj-page-header">
        <h1>{{ org.name }}</h1>
        <p>Manage members and invitations.</p>
    </div>

    {% if flash_error %}
        <div class="rj-alert rj-alert--danger">
            <i data-lucide="circle-x"></i>
            <div class="rj-alert__body">{{ flash_error }}</div>
        </div>
    {% endif %}
    {% if flash_success %}
        <div class="rj-alert rj-alert--success">
            <i data-lucide="check-circle-2"></i>
            <div class="rj-alert__body">{{ flash_success }}</div>
        </div>
    {% endif %}

    <div class="rj-admin-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Invite member</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/account/orgs/{{ org.id }}/invites">
                    <label>
                        <span>Email</span>
                        <input type="email" name="email" required placeholder="person@example.org">
                    </label>
                    <label>
                        <span>Role</span>
                        <select name="role">
                            <option value="MEMBER">Member</option>
                            <option value="MANAGER">Manager</option>
                        </select>
                    </label>
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                        <i data-lucide="plus"></i> Send invite
                    </button>
                </form>
            </div>
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Pending invites</h2></div>
            <div class="rj-admin-panel__body">
                {% if org.invites|length == 0 %}
                    <p class="rj-admin-empty">No pending invites.</p>
                {% else %}
                    <div class="rj-table-wrap">
                        <table class="rj-table rj-admin-table">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Expires</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for invite in org.invites %}
                                    <tr>
                                        <td>{{ invite.email }}</td>
                                        <td>{{ invite.role|lower }}</td>
                                        <td class="rj-num">{{ invite.expiresAt|date("M j, Y") }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Members</h2></div>
        <div class="rj-admin-panel__body">
        <div class="rj-table-wrap">
            <table class="rj-table rj-admin-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Role</th>
                        <th>Joined</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for membership in org.memberships %}
                        <tr>
                            <td>{{ membership.user.email }}<br><span class="rj-admin-muted">{{ membership.user.name ?? 'No name' }}</span></td>
                            <td>
                                <form method="post" action="/account/orgs/{{ org.id }}/memberships/{{ membership.id }}/role" class="rj-admin-inline-form">
                                    <select name="role">
                                        <option value="MEMBER"{% if membership.role == 'MEMBER' %} selected{% endif %}>Member</option>
                                        <option value="MANAGER"{% if membership.role == 'MANAGER' %} selected{% endif %}>Manager</option>
                                    </select>
                                    <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">Update</button>
                                </form>
                            </td>
                            <td class="rj-num">{{ membership.createdAt|date("M j, Y") }}</td>
                            <td>
                                <form method="post" action="/account/orgs/{{ org.id }}/memberships/{{ membership.id }}/remove">
                                    <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit">Remove</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="4" class="rj-table__empty">No members found.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        </div>
    </section>
{% endblock %}
