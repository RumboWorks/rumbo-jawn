{% extends "layouts/app.twig" %}

{% block title %}{{ org.name }} members — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/account/_sidebar.twig" with { org: org, active: org.id } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: org.name,
        subtitle: 'Manage members and invitations.'
    } %}

    {% if flash_error %}
        <div class="rj-alert rj-alert--danger">
            <i data-lucide="circle-x"></i>
            <div class="rj-alert__body">{{ flash_error }}</div>
        </div>
    {% endif %}
    {% if flash_success %}
        <div class="rj-alert rj-alert--success">
            <i data-lucide="check-circle-2"></i>
            <div class="rj-alert__body">{{ flash_success }}</div>
        </div>
    {% endif %}

    <div class="rj-admin-grid">
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Invite member</h2></div>
            <div class="rj-admin-panel__body">
                <form class="rj-admin-form" method="post" action="/account/orgs/{{ org.id }}/invites">
                    <label>
                        <span>Email</span>
                        <input type="email" name="email" required placeholder="person@example.org">
                    </label>
                    <label>
                        <span>Role</span>
                        <select name="role">
                            <option value="MEMBER">Member</option>
                            <option value="MANAGER">Manager</option>
                        </select>
                    </label>
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit">
                        <i data-lucide="plus"></i> Send invite
                    </button>
                </form>
            </div>
        </section>

        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Pending invites</h2></div>
            <div class="rj-admin-panel__body">
                {% if org.invites|length == 0 %}
                    <p class="rj-admin-empty">No pending invites.</p>
                {% else %}
                    <div class="rj-table-wrap">
                        <table class="rj-table rj-admin-table">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Expires</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for invite in org.invites %}
                                    <tr>
                                        <td>{{ invite.email }}</td>
                                        <td>{{ invite.role|lower }}</td>
                                        <td class="rj-num">{{ invite.expiresAt|date("M j, Y") }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </section>
    </div>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Members</h2></div>
        <div class="rj-admin-panel__body">
            {% if org.memberships|length == 0 %}
                <p class="rj-admin-empty">No members found.</p>
            {% else %}
                <div class="rj-list">
                    {% for membership in org.memberships %}
                        {% include "pages/account/_member-row.twig" %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </section>
{% endblock %}
