{% extends "layouts/app.twig" %}

{% block title %}Account — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/account/_sidebar.twig" with { account: account, active: 'profile' } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: currentUserFirstName ~ "'s account",
        subtitle: 'Manage your profile, password, and access.'
    } %}

    {% if flash_error %}
        <div class="rj-alert rj-alert--danger">
            <i data-lucide="circle-x"></i>
            <div class="rj-alert__body">{{ flash_error }}</div>
        </div>
    {% endif %}
    {% if flash_success %}
        <div class="rj-alert rj-alert--success">
            <i data-lucide="check-circle-2"></i>
            <div class="rj-alert__body">{{ flash_success }}</div>
        </div>
    {% endif %}

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Sign-in</h2></div>
        <div class="rj-admin-panel__body">
            <div class="rj-list">
                {% include "pages/account/_profile-row.twig" %}
                {% include "pages/account/_password-row.twig" %}
            </div>
        </div>
    </section>

    {% if usage %}
        <section class="rj-admin-panel">
            <div class="rj-admin-panel__header"><h2>Usage — {{ usage.orgName }}</h2></div>
            <div class="rj-admin-panel__body">
                <dl class="rj-admin-kv">
                    {% if usage.slu %}
                        <dt>Sounds Like Us analyses</dt>
                        <dd>
                            <span class="rj-num">{{ usage.slu.used }} / {{ usage.slu.limit }}</span>
                            <span class="rj-admin-muted">in the last {{ usage.slu.windowDays }} days</span>
                            {% if usage.slu.overBudget %}
                                <span class="rj-badge rj-badge--warning"><span class="rj-dot"></span>Over budget</span>
                            {% endif %}
                        </dd>
                    {% endif %}
                    {% if usage.eval %}
                        <dt>Eval response collections</dt>
                        <dd>
                            <span class="rj-num">{{ usage.eval.used }} / {{ usage.eval.limit }}</span>
                            <span class="rj-admin-muted">in the last {{ usage.eval.windowDays }} days</span>
                            {% if usage.eval.overBudget %}
                                <span class="rj-badge rj-badge--warning"><span class="rj-dot"></span>Over budget</span>
                            {% endif %}
                        </dd>
                    {% endif %}
                </dl>
                <p class="rj-admin-muted">Budgets are soft limits — going over flags usage but doesn't block you. Need more? See <a href="/billing">Billing</a>.</p>
            </div>
        </section>
    {% endif %}

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Access</h2></div>
        <div class="rj-admin-panel__body">
        <dl class="rj-admin-kv">
            <dt>Status</dt>
            <dd>{{ account.status }}</dd>
            {% if account.isPlatformAdmin %}
                <dt>Platform admin</dt>
                <dd>Yes</dd>
            {% endif %}
            <dt>Organizations</dt>
            <dd>
                {% if account.visibleMemberships|length == 0 %}
                    <span class="rj-admin-muted">No team organizations.</span>
                {% else %}
                    {% for membership in account.visibleMemberships %}
                        <div>
                            {% if membership.role == 'MANAGER' %}
                                <a href="/account/orgs/{{ membership.org.id }}/members">{{ membership.org.name }}</a>
                            {% else %}
                                {{ membership.org.name }}
                            {% endif %}
                            <span class="rj-admin-muted">{{ membership.role|lower }}</span>
                        </div>
                    {% endfor %}
                {% endif %}
            </dd>
            {% if account.partnerMemberships|length > 0 %}
                <dt>Partners</dt>
                <dd>
                    {% for membership in account.partnerMemberships %}
                        <div>{{ membership.partnerAccount.name }} <span class="rj-admin-muted">{{ membership.role|lower }}</span></div>
                    {% endfor %}
                </dd>
            {% endif %}
        </dl>
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Delete account</h2></div>
        <div class="rj-admin-panel__body">
            <p class="rj-admin-muted">Deleting anonymizes your account permanently: your name and email are removed, sign-in stops working, and personal workspaces with no other members are archived. Active subscriptions must be cancelled first from <a href="/billing">Billing</a>. This cannot be undone.</p>
            <form class="rj-admin-form" method="post" action="/account/delete">
                <button class="rj-btn rj-btn--danger rj-btn--sm" type="submit"
                        data-confirm="Permanently delete your account? Your name and email are removed and sign-in stops working. This cannot be undone."
                        data-confirm-title="Delete your account"
                        data-confirm-confirm="Delete my account"
                        data-confirm-danger
                        data-confirm-match="{{ account.email|e('html_attr') }}"
                        data-confirm-match-name="confirmEmail"
                        data-confirm-match-label="Type your email ({{ account.email|e('html_attr') }}) to confirm">
                    <i data-lucide="trash-2"></i> Delete my account
                </button>
            </form>
        </div>
    </section>
{% endblock %}
