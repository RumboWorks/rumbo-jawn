{% extends "layouts/app.twig" %}

{% block title %}Account — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/account/_sidebar.twig" with { account: account, active: 'profile' } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: currentUserFirstName ~ "'s account",
        subtitle: 'Manage your profile, password, and access.'
    } %}

    {% if flash_error %}
        <div class="rj-alert rj-alert--danger">
            <i data-lucide="circle-x"></i>
            <div class="rj-alert__body">{{ flash_error }}</div>
        </div>
    {% endif %}
    {% if flash_success %}
        <div class="rj-alert rj-alert--success">
            <i data-lucide="check-circle-2"></i>
            <div class="rj-alert__body">{{ flash_success }}</div>
        </div>
    {% endif %}

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Sign-in</h2></div>
        <div class="rj-admin-panel__body">
            <div class="rj-list">
                {% include "pages/account/_profile-row.twig" %}
                {% include "pages/account/_password-row.twig" %}
            </div>
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Access</h2></div>
        <div class="rj-admin-panel__body">
        <dl class="rj-admin-kv">
            <dt>Status</dt>
            <dd>{{ account.status }}</dd>
            <dt>Platform admin</dt>
            <dd>{% if account.isPlatformAdmin %}Yes{% else %}No{% endif %}</dd>
            <dt>Organizations</dt>
            <dd>
                {% if account.visibleMemberships|length == 0 %}
                    <span class="rj-admin-muted">No team organizations.</span>
                {% else %}
                    {% for membership in account.visibleMemberships %}
                        <div>
                            {% if membership.role == 'MANAGER' %}
                                <a href="/account/orgs/{{ membership.org.id }}/members">{{ membership.org.name }}</a>
                            {% else %}
                                {{ membership.org.name }}
                            {% endif %}
                            <span class="rj-admin-muted">{{ membership.role|lower }}</span>
                        </div>
                    {% endfor %}
                {% endif %}
            </dd>
            <dt>Partners</dt>
            <dd>
                {% if account.partnerMemberships|length == 0 %}
                    <span class="rj-admin-muted">None</span>
                {% else %}
                    {% for membership in account.partnerMemberships %}
                        <div>{{ membership.partnerAccount.name }} <span class="rj-admin-muted">{{ membership.role|lower }}</span></div>
                    {% endfor %}
                {% endif %}
            </dd>
        </dl>
        </div>
    </section>
{% endblock %}
