{% extends "layouts/app.twig" %}

{% block title %}Run {{ run.runNumber }} — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/eval/_sidebar.twig" with { active: 'evals', toolRole: toolRole } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: 'Run ' ~ run.runNumber,
        subtitle: run.eval.title,
        breadcrumbs: [
            { label: 'Evaluations', href: '/eval/evals' },
            { label: run.eval.title, href: '/eval/evals/' ~ run.eval.publicId },
            { label: 'Run ' ~ run.runNumber }
        ]
    } %}

    {% include "pages/eval/_flash.twig" %}

    <section class="rj-admin-metrics rj-admin-metrics--compact">
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Status</span>
            <strong><span class="eval-status eval-status--{{ run.status|lower }}">{{ run.status|replace({'_': ' '})|lower }}</span></strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Responses</span>
            <strong>{{ progress.collected }} / {{ progress.total }}</strong>
        </div>
        <div class="rj-admin-metric">
            <span class="rj-admin-metric__label">Criteria</span>
            <strong>{{ run.criterionSnapshots|length }}</strong>
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Run controls</h2></div>
        <div class="rj-admin-panel__body">
        <div class="rj-form-actions">
            {% if run.status == 'COLLECTING_RESPONSES' %}
                <form method="post" action="/eval/runs/{{ run.publicId }}/status">
                    <input type="hidden" name="status" value="READY_FOR_REVIEWS">
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit"{% if progress.missing > 0 %} disabled title="Collect all responses first"{% endif %}>
                        <i data-lucide="check-circle-2"></i> Mark ready for reviews
                    </button>
                </form>
            {% elseif run.status == 'READY_FOR_REVIEWS' %}
                <form method="post" action="/eval/runs/{{ run.publicId }}/status">
                    <input type="hidden" name="status" value="IN_REVIEW">
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit"{% if assignments is empty %} disabled title="Assign at least one reviewer"{% endif %}>
                        <i data-lucide="sparkles"></i> Open for review
                    </button>
                </form>
                <form method="post" action="/eval/runs/{{ run.publicId }}/status">
                    <input type="hidden" name="status" value="COLLECTING_RESPONSES">
                    <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit">Reopen collection</button>
                </form>
            {% elseif run.status == 'IN_REVIEW' %}
                <span class="rj-admin-muted">{{ completedCount }} of {{ assignments|length }} reviewer{{ assignments|length == 1 ? '' : 's' }} submitted.</span>
                <form method="post" action="/eval/runs/{{ run.publicId }}/remind">
                    <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit"><i data-lucide="clock"></i> Send reminders</button>
                </form>
                <form method="post" action="/eval/runs/{{ run.publicId }}/status">
                    <input type="hidden" name="status" value="COMPLETED">
                    <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit"><i data-lucide="check-circle-2"></i> Close review &amp; build report</button>
                </form>
            {% elseif run.status == 'COMPLETED' %}
                <a href="/eval/runs/{{ run.publicId }}/report" class="rj-btn rj-btn--primary rj-btn--sm"><i data-lucide="clipboard-check"></i> View report</a>
                <form method="post" action="/eval/runs/{{ run.publicId }}/status">
                    <input type="hidden" name="status" value="IN_REVIEW">
                    <button class="rj-btn rj-btn--ghost rj-btn--sm" type="submit">Reopen review</button>
                </form>
            {% endif %}
        </div>
        {% if budget and budget.overLimit %}
            <p class="rj-admin-muted">Response-collection budget reached for this period; API collection may be blocked.</p>
        {% endif %}
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Reviewers</h2></div>
        <div class="rj-admin-panel__body">
        {% if reviewers is empty %}
            <p class="eval-empty">No one in this organization has Eval access yet. A platform admin grants per-tool access on the user's admin page.</p>
        {% else %}
            <form method="post" action="/eval/runs/{{ run.publicId }}/reviewers">
                {% for rv in reviewers %}
                    {% set done = false %}
                    {% for a in assignments %}{% if a.userId == rv.id and a.completedAt %}{% set done = true %}{% endif %}{% endfor %}
                    <label class="eval-check">
                        <input type="checkbox" name="reviewerIds" value="{{ rv.id }}"{% if rv.assigned %} checked{% endif %}{% if done %} disabled{% endif %}>
                        <span>{{ rv.name ?? rv.email }} <span class="rj-admin-muted">· {{ rv.role|lower }}</span>
                            {% if done %}<span class="eval-status eval-status--completed">submitted</span>{% endif %}
                        </span>
                    </label>
                    {% if done %}<input type="hidden" name="reviewerIds" value="{{ rv.id }}">{% endif %}
                {% endfor %}
                <div class="rj-form-actions">
                    <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit">Save reviewers</button>
                </div>
            </form>
        {% endif %}
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Responses</h2></div>
        <div class="rj-admin-panel__body">
            <div class="rj-table-wrap">
                <table class="rj-table rj-admin-table">
                    <thead>
                        <tr><th>Model</th><th>Source</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        {% for r in run.responses %}
                            <tr>
                                <td>{{ r.modelSnapshot.displayName }}{% if r.modelSnapshot.providerModelName %}<br><span class="rj-admin-muted">{{ r.modelSnapshot.providerModelName }}</span>{% endif %}</td>
                                <td>{{ r.responseSource|replace({'_': ' '})|lower }}</td>
                                <td>{% if r.collected %}<span class="eval-status eval-status--ready_for_reviews">collected</span>{% else %}<span class="eval-status eval-status--collecting_responses">pending</span>{% endif %}</td>
                                <td>
                                    <div class="rj-item__actions">
                                        {% if r.liveCollectable %}
                                            <form method="post" action="/eval/responses/{{ r.publicId }}/collect">
                                                <button class="rj-btn rj-btn--secondary rj-btn--sm" type="submit"><i data-lucide="sparkles"></i> {{ r.collected ? 'Re-collect' : 'Collect via API' }}</button>
                                            </form>
                                        {% endif %}
                                        <a href="/eval/responses/{{ r.publicId }}/manual" class="rj-btn rj-btn--ghost rj-btn--sm">{{ r.collected ? 'Edit' : 'Enter manually' }}</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <p class="rj-admin-muted">API responses are collected in the background — refresh to see results.</p>
        </div>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Prompt</h2></div>
        <div class="rj-admin-panel__body">
            <pre class="eval-prompt">{{ run.promptSnapshot.promptText }}</pre>
        </div>
    </section>
{% endblock %}
