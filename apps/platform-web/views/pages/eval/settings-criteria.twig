{% extends "layouts/app.twig" %}

{% block title %}Eval criteria — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/eval/_sidebar.twig" with { active: 'criteria', toolRole: toolRole } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: 'Evaluation criteria',
        subtitle: 'Reusable criteria reviewers score responses against. Snapshotted into a run when it launches.',
        action: { label: 'Add criterion', href: '/eval/settings/criteria/new', icon: 'plus' }
    } %}

    {% include "pages/eval/_flash.twig" %}

    {% if criteria is not empty %}
        <div class="rj-list">
            {% for c in criteria %}
                {% include "pages/eval/_criterion-row.twig" %}
            {% endfor %}
        </div>
    {% else %}
        <div class="rj-list">
            <p class="rj-list__empty">No criteria yet. <a href="/eval/settings/criteria/new">Add your first criterion</a>.</p>
        </div>
    {% endif %}
{% endblock %}
