{% extends "layouts/app.twig" %}

{% block title %}Eval — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/eval/_sidebar.twig" with { active: 'overview', toolRole: toolRole } %}
{% endblock %}

{% block content %}
    <div class="eval-desk">
        <div class="rj-page-header">
            <h1 class="eval-desk__title">{{ currentUserFirstName }}’s Desk</h1>
            <p class="eval-desk__subtitle">Evaluate AI model and tool outputs against your criteria.</p>
        </div>

        {% include "pages/eval/_flash.twig" %}

        {% if myTasks is not empty %}
            <section class="eval-desk__section">
                <h2 class="eval-desk__section-title">Your tasks</h2>
                <div class="rj-table-wrap eval-table-wrap">
                    <table class="rj-table">
                        <thead><tr><th>Task</th><th>Evaluation</th><th class="eval-table__col--actions"></th></tr></thead>
                        <tbody>
                            {% for t in myTasks %}
                                <tr>
                                    <td>
                                        {% if t.taskType == 'REVIEW_RESPONSES' %}Review responses
                                        {% elseif t.taskType == 'COLLECT_MANUAL_RESPONSE' %}Collect a response{% if t.response %}: {{ t.response.modelSnapshot.displayName }}{% endif %}
                                        {% else %}{{ t.taskType|replace({'_': ' '})|lower }}{% endif %}
                                    </td>
                                    <td>{{ t.evalRun.eval.title }} · run {{ t.evalRun.runNumber }}</td>
                                    <td class="eval-table__cell--actions"><a href="{{ t.href }}" class="rj-btn rj-btn--secondary rj-btn--sm">Open</a></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        {% endif %}

        {% if myReviews is not empty %}
            <section class="eval-desk__section">
                <h2 class="eval-desk__section-title">Your reviews</h2>
                <div class="rj-table-wrap eval-table-wrap">
                    <table class="rj-table">
                        <thead><tr><th>Evaluation</th><th>Status</th><th class="eval-table__col--actions"></th></tr></thead>
                        <tbody>
                            {% for run in myReviews %}
                                <tr>
                                    <td>{{ run.eval.title }}</td>
                                    <td>Run {{ run.runNumber }} · awaiting your review</td>
                                    <td class="eval-table__cell--actions"><a href="/eval/runs/{{ run.publicId }}/review" class="rj-btn rj-btn--primary rj-btn--sm">Review</a></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        {% endif %}

        <section class="eval-desk__section">
            <h2 class="eval-desk__section-title">Evaluations</h2>
            {% if summary.recentEvals is empty %}
                <p class="eval-empty">No evaluations yet.
                    {% if toolRole == 'MANAGER' %}
                        Set up your <a href="/eval/settings/models">models</a> and <a href="/eval/settings/criteria">criteria</a>, then <a href="/eval/evals/new">create an evaluation</a>.
                    {% else %}
                        A manager can set up evaluations for your team.
                    {% endif %}
                </p>
            {% elseif toolRole == 'MANAGER' %}
                {% set drafts = [] %}{% set active = [] %}{% set completed = [] %}
                {% for ev in summary.recentEvals %}
                    {% set latest = ev.runs[0] ?? null %}
                    {% if not latest %}{% set drafts = drafts|merge([ev]) %}
                    {% elseif latest.status == 'COMPLETED' %}{% set completed = completed|merge([ev]) %}
                    {% else %}{% set active = active|merge([ev]) %}{% endif %}
                {% endfor %}
                {% include "pages/eval/_eval-table.twig" with { heading: 'Draft', items: drafts } %}
                {% include "pages/eval/_eval-table.twig" with { heading: 'In progress', items: active } %}
                {% include "pages/eval/_eval-table.twig" with { heading: 'Completed', items: completed } %}
            {% endif %}
        </section>
    </div>
{% endblock %}
