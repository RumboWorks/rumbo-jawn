{% extends "layouts/app.twig" %}

{% block title %}Report — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/eval/_sidebar.twig" with { active: 'evals', toolRole: toolRole } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: run.eval.title ~ ' — report',
        subtitle: 'Run ' ~ run.runNumber
    } %}

    {% include "pages/eval/_flash.twig" %}

    <p><a href="/eval/runs/{{ run.publicId }}">&larr; Back to run</a></p>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Scores</h2></div>
        {% include "pages/eval/_report-matrix.twig" %}
    </section>

    <dialog class="eval-drilldown" id="eval-report-drilldown">
        <button class="eval-drilldown__close" type="button" data-dialog-close aria-label="Close">×</button>
        <h2 id="eval-drilldown-title">Score details</h2>
        <div id="eval-drilldown-body"></div>
    </dialog>
    <script type="application/json" id="eval-report-drilldowns">{{ drilldowns|json_encode|raw }}</script>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Summary &amp; recommendation</h2></div>
        <form class="rj-admin-form" method="post" action="/eval/runs/{{ run.publicId }}/report">
            <label>
                <span>Summary</span>
                <textarea name="summaryText" rows="4" placeholder="What the scores show…">{{ report.summaryText ?? '' }}</textarea>
            </label>
            <label>
                <span>Recommendation</span>
                <textarea name="recommendationText" rows="3" placeholder="What to do next…">{{ report.recommendationText ?? '' }}</textarea>
            </label>
            <div class="rj-form-actions">
                <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit"><i data-lucide="save"></i> Save report</button>
            </div>
        </form>
    </section>

    <section class="rj-admin-panel">
        <div class="rj-admin-panel__header"><h2>Secure share link</h2></div>
        <form class="rj-admin-form" method="post" action="/eval/runs/{{ run.publicId }}/report/share">
            <label class="eval-check">
                <input type="checkbox" name="enabled"{% if report.secureShareEnabled %} checked{% endif %} onchange="this.form.submit()">
                <span>Anyone with the link can view this report (read-only, model names hidden)</span>
            </label>
        </form>
        {% if report.secureShareEnabled and report.secureShareToken %}
            <p class="rj-admin-muted">Share link:
                <a href="{{ shareBase }}{{ report.secureShareToken }}">{{ shareBase }}{{ report.secureShareToken }}</a>
            </p>
        {% endif %}
    </section>
{% endblock %}
