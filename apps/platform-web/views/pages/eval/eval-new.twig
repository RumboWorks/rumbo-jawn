{% extends "layouts/app.twig" %}

{% block title %}New evaluation — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/eval/_sidebar.twig" with { active: 'evals', toolRole: toolRole } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with { heading: 'New evaluation' } %}

    {% include "pages/eval/_flash.twig" %}

    <section class="rj-admin-panel">
        <form class="rj-admin-form" method="post" action="/eval/evals">
            <label>
                <span>Title</span>
                <input type="text" name="title" required autofocus placeholder="e.g. Newsletter intro lines">
            </label>
            <label>
                <span>Description</span>
                <input type="text" name="description" placeholder="What this evaluation is for (optional)">
            </label>
            <div class="rj-form-actions">
                <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit"><i data-lucide="plus"></i> Create evaluation</button>
                <a class="rj-btn rj-btn--ghost rj-btn--sm" href="/eval/evals">Cancel</a>
            </div>
        </form>
    </section>
{% endblock %}
