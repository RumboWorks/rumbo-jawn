{% extends "layouts/app.twig" %}

{% block title %}Evaluations — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/eval/_sidebar.twig" with { active: 'evals', toolRole: toolRole } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: 'Evaluations',
        subtitle: 'Each evaluation holds a prompt and a history of runs against your models and criteria.',
        action: { label: 'New evaluation', href: '/eval/evals/new', icon: 'plus' }
    } %}

    {% include "pages/eval/_flash.twig" %}

    {% set drafts = [] %}
    {% set active = [] %}
    {% set completed = [] %}
    {% for ev in evals %}
        {% set latest = ev.runs[0] ?? null %}
        {% if not latest %}{% set drafts = drafts|merge([ev]) %}
        {% elseif latest.status == 'COMPLETED' %}{% set completed = completed|merge([ev]) %}
        {% else %}{% set active = active|merge([ev]) %}{% endif %}
    {% endfor %}
    {% if evals is empty %}
        <div class="rj-list">
            <p class="rj-list__empty">No evaluations yet. <a href="/eval/evals/new">Create your first evaluation</a>.</p>
        </div>
    {% else %}
        {% include "pages/eval/_eval-table.twig" with { heading: 'Draft', items: drafts } %}
        {% include "pages/eval/_eval-table.twig" with { heading: 'In progress', items: active } %}
        {% include "pages/eval/_eval-table.twig" with { heading: 'Completed', items: completed } %}
    {% endif %}
{% endblock %}
