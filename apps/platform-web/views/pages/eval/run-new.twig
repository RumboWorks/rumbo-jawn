{% extends "layouts/app.twig" %}

{% block title %}New run — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/eval/_sidebar.twig" with { active: 'evals', toolRole: toolRole } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with { heading: 'New run', subtitle: eval.title } %}

    {% include "pages/eval/_flash.twig" %}

    <p><a href="/eval/evals/{{ eval.publicId }}">&larr; Back to {{ eval.title }}</a></p>

    {% if criteria is empty or models is empty %}
        <div class="rj-alert rj-alert--danger">
            <i data-lucide="circle-alert"></i>
            <div class="rj-alert__body">
                You need at least one
                {% if models is empty %}<a href="/eval/settings/models/new">model</a>{% endif %}
                {% if models is empty and criteria is empty %} and one {% endif %}
                {% if criteria is empty %}<a href="/eval/settings/criteria/new">criterion</a>{% endif %}
                before launching a run.
            </div>
        </div>
    {% else %}
        <form class="rj-admin-form" method="post" action="/eval/evals/{{ eval.publicId }}/runs">
            <label>
                <span>Prompt</span>
                <textarea name="promptText" rows="6" required placeholder="The prompt sent to each model under test."></textarea>
            </label>

            <fieldset class="eval-fieldset">
                <legend>Models</legend>
                {% for m in models %}
                    <label class="eval-check">
                        <input type="checkbox" name="modelIds" value="{{ m.id }}">
                        <span>{{ m.displayName }}
                            <span class="rj-admin-muted">· {{ m.accessMethod|replace({'_': ' '})|title }}{% if m.provider %} · {{ m.provider.name }}{% endif %}</span>
                        </span>
                    </label>
                {% endfor %}
            </fieldset>

            <fieldset class="eval-fieldset">
                <legend>Criteria</legend>
                {% for c in criteria %}
                    <label class="eval-check">
                        <input type="checkbox" name="criterionIds" value="{{ c.id }}">
                        <span>{{ c.title }}{% if c.description %} <span class="rj-admin-muted">· {{ c.description }}</span>{% endif %}</span>
                    </label>
                {% endfor %}
            </fieldset>

            <fieldset class="eval-fieldset">
                <legend>Options</legend>
                <label class="eval-check"><input type="checkbox" name="hideModelNames"> <span>Hide model names from reviewers</span></label>
                <label class="eval-check"><input type="checkbox" name="hidePeerReviews"> <span>Hide other reviewers' input</span></label>
                <label>
                    <span>Review closes (optional)</span>
                    <input type="datetime-local" name="reviewClosesAt">
                </label>
            </fieldset>

            <div class="rj-form-actions">
                <button class="rj-btn rj-btn--primary rj-btn--sm" type="submit"><i data-lucide="sparkles"></i> Launch run</button>
                <a class="rj-btn rj-btn--ghost rj-btn--sm" href="/eval/evals/{{ eval.publicId }}">Cancel</a>
            </div>
        </form>
    {% endif %}
{% endblock %}
