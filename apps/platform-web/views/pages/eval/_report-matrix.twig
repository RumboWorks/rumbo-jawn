{# Report heatmap: models (rows) × criteria (columns). Needs `matrix`,
   `criteria`, `criterionAverages`, `overall`, `overallHeatClass` in scope.
   The Score/Rank control lives outside this partial (_matrix-mode.twig, one per
   page) so a single switch can drive every matrix in its scope. #}
<div class="rj-table-wrap">
    <table class="rj-table eval-matrix" data-eval-matrix>
            <thead>
                <tr>
                    <th class="eval-matrix__model-head" data-sort-col="0">Model</th>
                    <th class="eval-matrix__avg-head" data-sort-col="1">Average</th>
                    {% for c in criteria %}<th data-sort-col="{{ loop.index + 1 }}">{{ c.title }}</th>{% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for row in matrix %}
                    <tr>
                        <td class="eval-matrix__model" data-model-name="{{ row.modelName }}">{{ row.modelName }}</td>
                        <td class="eval-heat eval-matrix__avg-cell {{ row.modelAvgHeatClass }}{% if row.modelAvg is not null %} eval-heat--clickable{% endif %}"
                            data-score="{{ row.modelAvg ?? '' }}"
                            data-model-id="{{ row.modelId }}"
                            data-model-name="{{ row.modelName }}">
                            <span class="eval-matrix__score eval-matrix__score--avg">{{ row.modelAvg is null ? '—' : row.modelAvg|number_format(1) }}</span>
                        </td>
                        {% for cell in row.cells %}
                            <td class="eval-heat {{ cell.heatClass }}{% if cell.average is not null %} eval-heat--clickable{% endif %}"
                                data-score="{{ cell.average ?? '' }}"
                                data-model-id="{{ row.modelId }}"
                                data-model-name="{{ row.modelName }}"
                                data-criterion-id="{{ cell.criterionId }}"
                                data-criterion-title="{{ cell.criterionTitle }}"
                                title="{{ cell.count }} rating{{ cell.count == 1 ? '' : 's' }}">
                                <span class="eval-matrix__score">{{ cell.average is null ? '—' : cell.average|number_format(1) }}</span>
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <td class="eval-matrix__model">Average</td>
                    <td class="eval-heat eval-matrix__avg-cell {{ overallHeatClass }}">
                        <span class="eval-matrix__score eval-matrix__score--avg">{{ overall is null ? '—' : overall|number_format(1) }}</span>
                    </td>
                    {% for ca in criterionAverages %}
                        <td class="eval-heat {{ ca.heatClass }}">
                            <span class="eval-matrix__score">{{ ca.average is null ? '—' : ca.average|number_format(1) }}</span>
                        </td>
                    {% endfor %}
                </tr>
            </tfoot>
        </table>
    </div>
