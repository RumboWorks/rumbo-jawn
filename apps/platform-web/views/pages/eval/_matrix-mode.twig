{# Single Score/Rank control for the matrices in the enclosing [data-matrix-scope].
   Pass `hideable: true` where it should be hidden on non-matrix tabs (e.g. Trend). #}
<div class="eval-matrix-footer"{% if hideable %} data-matrix-footer{% endif %}>
    <span class="rj-admin-muted">Score: low 1 → 5 high</span>
    <div class="rj-segmented eval-mode-switch" role="radiogroup" aria-label="Matrix display mode" data-rank-switch>
        <span class="rj-segmented__indicator" aria-hidden="true"></span>
        <button type="button" class="rj-segmented__btn is-active" data-mode="score"><span class="rj-segmented__label">Score</span></button>
        <button type="button" class="rj-segmented__btn" data-mode="rank"><span class="rj-segmented__label">Rank</span></button>
    </div>
</div>
