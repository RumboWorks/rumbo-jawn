{% extends "layouts/app.twig" %}

{% block title %}Reports — Rumbo{% endblock %}
{% block sidebar %}{% include "pages/eval/_sidebar.twig" with { active: 'reports', toolRole: toolRole } %}{% endblock %}

{% block content %}
    {% set helpContextKey = 'eval.reports' %}
    {% include "partials/page-header.twig" with {
        heading: 'Reports',
        subtitle: 'Completed evaluation reports for this organization.'
    } %}
    {% include "pages/eval/_flash.twig" %}

    {# Evaluations are primary; their completed runs sit beneath. #}
    {% for group in reportGroups %}
        <section class="eval-list-section">
            <h2 class="eval-list-section__title">
                <a href="/eval/evals/{{ group.publicId }}">{{ group.title }}</a>
                <span class="eval-list-section__count">{{ group.reports|length }}</span>
            </h2>
            <div class="rj-table-wrap">
                <table class="rj-table rj-admin-table" data-no-sort>
                    <tbody>
                        {% for report in group.reports %}
                            <tr>
                                <td>Run {{ report.evalRun.runNumber }}</td>
                                <td class="rj-num">{{ report.createdAt|date("M j, Y") }}</td>
                                <td><a class="rj-btn rj-btn--secondary rj-btn--sm" href="/eval/runs/{{ report.evalRun.publicId }}/report">View report</a></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% else %}
        <div class="rj-list">
            <p class="rj-list__empty">No completed reports yet.</p>
        </div>
    {% endfor %}
{% endblock %}
