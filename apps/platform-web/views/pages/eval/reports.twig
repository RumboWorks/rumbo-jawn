{% extends "layouts/app.twig" %}

{% block title %}Reports — Rumbo{% endblock %}
{% block sidebar %}{% include "pages/eval/_sidebar.twig" with { active: 'reports', toolRole: toolRole } %}{% endblock %}

{% block content %}
    {% set helpContextKey = 'eval.reports' %}
    {% include "partials/page-header.twig" with {
        heading: 'Reports',
        subtitle: 'Completed evaluation reports for this organization.'
    } %}
    {% include "pages/eval/_flash.twig" %}
    <div class="rj-table-wrap">
        <table class="rj-table rj-admin-table">
            <thead><tr><th>Evaluation</th><th>Run</th><th>Created</th><th></th></tr></thead>
            <tbody>
                {% for report in reports %}
                    <tr>
                        <td>{{ report.evalRun.eval.title }}</td>
                        <td>Run {{ report.evalRun.runNumber }}</td>
                        <td>{{ report.createdAt|date("M j, Y") }}</td>
                        <td><a class="rj-btn rj-btn--secondary rj-btn--sm" href="/eval/runs/{{ report.evalRun.publicId }}/report">View report</a></td>
                    </tr>
                {% else %}
                    <tr><td colspan="4" class="rj-table__empty">No completed reports yet.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
