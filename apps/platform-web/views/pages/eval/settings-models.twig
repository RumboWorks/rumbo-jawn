{% extends "layouts/app.twig" %}

{% block title %}Eval models — Rumbo{% endblock %}

{% block sidebar %}
    {% include "pages/eval/_sidebar.twig" with { active: 'models', toolRole: toolRole } %}
{% endblock %}

{% block content %}
    {% include "partials/page-header.twig" with {
        heading: 'Models',
        subtitle: 'The AI models and tools this organization evaluates, collected by platform API, your own API key, or manual entry.',
        action: { label: 'Add model', href: '/eval/settings/models/new', icon: 'plus' }
    } %}

    {% include "pages/eval/_flash.twig" %}

    {% if models is not empty %}
        <div class="rj-list">
            {% for model in models %}
                {% include "pages/eval/_model-row.twig" %}
            {% endfor %}
        </div>
    {% else %}
        <div class="rj-list">
            <p class="rj-list__empty">No models yet. <a href="/eval/settings/models/new">Add your first model</a>.</p>
        </div>
    {% endif %}
{% endblock %}
