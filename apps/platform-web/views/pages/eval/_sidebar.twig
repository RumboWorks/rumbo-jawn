<span class="rj-sidebar__label">Eval</span>
<div class="rj-sidebar__section">
    <a href="/eval" class="rj-sidebar__link{% if active == 'overview' %} is-active{% endif %}">
        <i data-lucide="layout-dashboard"></i> Overview
    </a>
    <a href="/eval/tasks" class="rj-sidebar__link{% if active == 'tasks' %} is-active{% endif %}">
        <i data-lucide="check-circle-2"></i> Tasks
    </a>
    {% if toolRole == 'MANAGER' %}
        <a href="/eval/evals" class="rj-sidebar__link{% if active == 'evals' %} is-active{% endif %}">
            <i data-lucide="clipboard-check"></i> Evaluations
        </a>
        <a href="/eval/reports" class="rj-sidebar__link{% if active == 'reports' %} is-active{% endif %}">
            <i data-lucide="bar-chart-3"></i> Reports
        </a>
    {% endif %}
</div>
{% if toolRole == 'MANAGER' %}
    <span class="rj-sidebar__label">Settings</span>
    <div class="rj-sidebar__section">
        <a href="/eval/settings/models" class="rj-sidebar__link{% if active == 'models' %} is-active{% endif %}">
            <i data-lucide="boxes"></i> Models
        </a>
        <a href="/eval/settings/criteria" class="rj-sidebar__link{% if active == 'criteria' %} is-active{% endif %}">
            <i data-lucide="list-checks"></i> Criteria
        </a>
    </div>
{% endif %}
