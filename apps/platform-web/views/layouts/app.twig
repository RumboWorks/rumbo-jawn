<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Rumbo{% endblock %}</title>
    <link rel="stylesheet" href="/dist/main.css">
</head>
<body class="rj-app-body">
    <header class="rj-header">
        <div class="rj-header__inner">
            <a href="/" class="rj-header__logo">Rumbo</a>
            <nav class="rj-header__nav">
                {% if currentUser %}
                    <span class="rj-header__nav-link">{{ currentUser.name ?? currentUser.email }}</span>
                    <a href="/auth/logout" class="rj-header__nav-link">Sign out</a>
                {% else %}
                    <a href="/login" class="rj-header__nav-link">Sign in</a>
                {% endif %}
            </nav>
        </div>
    </header>

    <div class="rj-app-shell">
        <nav class="rj-sidebar">
            {% block sidebar %}{% endblock %}
        </nav>

        <main class="rj-app-content">
            {% block content %}{% endblock %}
        </main>
    </div>

    <script type="module" src="/dist/main.js"></script>
</body>
</html>
