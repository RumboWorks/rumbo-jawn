<!DOCTYPE html>
<html lang="en" data-nav-orientation="{{ navOrientation ?? 'horizontal' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Rumbo{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,500;0,600;0,700;1,500&family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Geist:wght@300;400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Newsreader:ital,opsz,wght@0,6..72,300..800;1,6..72,300..800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="/brand/rumboworks-mark.svg">
    <link rel="alternate icon" href="/favicon.ico">
    <link rel="stylesheet" href="/dist/main.css">
    <script>
        (function() {
            var t = localStorage.getItem('rj-theme') || 'paper';
            var d = localStorage.getItem('rj-density') || 'comfortable';
            document.documentElement.setAttribute('data-theme', t);
            document.documentElement.setAttribute('data-density', d);
        })();
    </script>
</head>
<body{% if tool is defined %} data-tool="{{ tool }}"{% endif %} style="display:flex;flex-direction:column;min-height:100vh;">
    <header class="rj-header">
        <div class="rj-header__inner">
            <a href="/" class="rj-logo">
                <img src="/brand/rumboworks-mark.svg" alt="" width="28" height="28">
                <span class="rj-wordmark">Rumbo</span>
            </a>
            {% if activeOrganization %}
                <form class="rj-org-switcher" method="post" action="/organization/switch">
                    <input type="hidden" name="returnTo" value="{{ currentPath ?? '/' }}">
                    <label class="rj-sr-only" for="rj-org-select">Organization</label>
                    <select id="rj-org-select" name="orgId" onchange="this.form.submit()">
                        {% for org in organizations %}
                            <option value="{{ org.id }}"{% if org.id == activeOrganization.id %} selected{% endif %}>{{ org.name }}</option>
                        {% endfor %}
                    </select>
                </form>
            {% endif %}
            {% block header_nav %}
            <nav class="rj-header__nav">
                {% if currentUser %}
                    {% if navTools is not empty %}
                        <details class="rj-tools-menu">
                            <summary class="rj-header__nav-link">Tools</summary>
                            <div class="rj-tools-menu__list">
                                {% for t in navTools %}
                                    <a href="{{ t.path }}" class="rj-tools-menu__item">{{ t.name }}</a>
                                {% endfor %}
                            </div>
                        </details>
                    {% endif %}
                    {% if currentUser.isPlatformAdmin %}
                        <a href="/admin" class="rj-header__nav-link">Admin</a>
                    {% endif %}
                    <button class="rj-nav-orientation-toggle" id="rj-nav-orientation-toggle" type="button" aria-label="Switch navigation layout" title="Switch navigation layout">
                        <i data-lucide="panel-left"></i>
                    </button>
                    <details class="rj-account-menu">
                        <summary class="rj-header__nav-link">{{ currentUserDisplayName }}</summary>
                        <div class="rj-account-menu__panel">
                            <a href="/account">My account</a>
                            <div class="rj-ui-options">
                                <label>Theme
                                    <select id="rj-theme-select" aria-label="Color theme">
                                        <option value="light">Light</option>
                                        <option value="dark">Dark</option>
                                        <option value="paper">Paper</option>
                                        <option value="pink">Pink</option>
                                    </select>
                                </label>
                                <label>Density
                                    <select id="rj-density-select" aria-label="Density">
                                        <option value="comfortable">Comfortable</option>
                                        <option value="compact">Compact</option>
                                    </select>
                                </label>
                            </div>
                            <a href="/auth/logout">Sign out</a>
                        </div>
                    </details>
                {% endif %}
            </nav>
            {% endblock %}
        </div>
    </header>

    <div class="rj-app-shell">
        <nav class="rj-sidebar">
            {% block sidebar %}{% endblock %}
        </nav>
        <main class="rj-app-content">
            {% block content %}{% endblock %}
        </main>
    </div>

    <script type="module" src="/dist/main.js"></script>
</body>
</html>
